script main(args: Args) -> Report {
    T_bad = measured(sensor_value, std=abc)
    Q_bad_dist = normal(mean=5 kW, std=-0.8 kW, samples=0)
    Q_bad_uniform = uniform(0.7 kW, 0.3 kW, samples=abc)
    Q_source = normal(mean=4 kW, std=0.4 kW, samples=9)
    Q_bad_prop = propagate(Q_source, method=quadratic, scale=abc)
    Q_bad_distribution = distribution(kind=triangular, mean=5 kW, std=0.2 kW)
}
