schema SensorData {
    time: DateTime index
    T_supply: AbsoluteTemperature [degC]
    T_return: AbsoluteTemperature [degC]
    m_dot: MassFlowRate [kg/s]
}

script main(args: Args) -> Report {
    sensor = promote csv "data/missing_column.csv" as SensorData

    return report {
        show sensor
    }
}

