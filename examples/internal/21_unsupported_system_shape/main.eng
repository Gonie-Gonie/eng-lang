system UnsupportedThermal {
    parameter C: HeatCapacity = 500 kJ/K
    state T: AbsoluteTemperature = 24 degC

    equation {
        C * der(T) eq 0 W
    }
}

sim = simulate UnsupportedThermal
with {
    timestep = 10 min
    solver = fixed_step
}

print "Unsupported system shape is reported as a skipped solver artifact"
