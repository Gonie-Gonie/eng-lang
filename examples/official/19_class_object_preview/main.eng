class Construction {
    name: String
    u_value: Conductance [W/K]
    thickness: Length [m] = 0.2 m
    validate {
        name != ""
        u_value > 0 W/K
        thickness > 0 m
    }
}

class Zone {
    name: String
    capacity: HeatCapacity [J/K]
    occupancy: Count = 1
    validate {
        name != ""
        capacity > 0 J/K
        occupancy >= 0
    }
}

class WeatherData {
    source: String
    temperature_column: String = "T_out"
    solar_column: String = "solar"
    validate {
        source != ""
        temperature_column != ""
    }
}

class Building {
    name: String
    zone: Zone
    envelope: Construction
    weather: WeatherData
    validate {
        name != ""
    }
}

wall = Construction {
    name = "south_wall"
    u_value = 120 W/K
}

office = Zone {
    name = "office"
    capacity = 120000 J/K
}

weather = WeatherData {
    source = "weather.csv"
}

building = Building {
    name = "Lab"
    zone = office
    envelope = wall
    weather = weather
}

wall_u = wall.u_value
building_name = building.name

print "Class object preview metadata ready"
