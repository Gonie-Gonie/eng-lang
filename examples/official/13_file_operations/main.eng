print "File operation support"

copy file("data/template.txt") to "ops/copied_note.txt"

mkdir "ops/archive"

move "ops/copied_note.txt" to "ops/archive/copied_note.txt"
with {
    confirm = true
    overwrite = true
}

write text "ops/scratch.txt", "temporary generated note"

delete "ops/scratch.txt"
with {
    confirm = true
}

write text "ops/tmp/stale.txt", "temporary generated directory note"

delete dir("ops/tmp")
with {
    recursive = true
    confirm = true
}
