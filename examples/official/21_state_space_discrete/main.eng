states RoomState {
    T_air: AbsoluteTemperature [degC]
    T_wall: AbsoluteTemperature [degC]
}

inputs RoomInput {
    Q_hvac: HeatRate [W]
}

system DiscreteRoomStateSpace {
    state x: StateVector[RoomState] = [20 degC, 19 degC]
    input u: InputVector[RoomInput] = [1200 W]

    operator A: LinearOperator[RoomState -> Derivative[RoomState]] = [[1.0, 0.0]; [0.0, 1.0]]
    operator B: LinearOperator[RoomInput -> Derivative[RoomState]] = [[0.001]; [0.0004]]

    equation {
        next(x) eq A * x + B * u
    }
}

sim = simulate DiscreteRoomStateSpace
with {
    timestep = 10 min
    duration = 30 min
    solver = fixed_step
}

print "Discrete state-space simulation recorded"

report {
    plot sim.T_air and sim.T_wall over Time
    with {
        unit y = degC
        title = "Discrete state-space room response"
    }
}
