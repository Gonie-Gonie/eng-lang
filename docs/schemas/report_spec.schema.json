{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/report_spec.schema.json",
  "title": "EngLang ReportSpec Artifact",
  "type": "object",
  "required": [
    "format",
    "report_schema_version",
    "compiler_version",
    "report_version",
    "source_path",
    "source_hash",
    "provenance",
    "variable_table",
    "args_summary",
    "arg_values",
    "schema_summary",
    "computed_statistics",
    "computed_integrations",
    "computed_metrics",
    "validations",
    "time_alignments",
    "policy_results",
    "domain_summary",
    "component_summary",
    "connection_summary",
    "system_summary",
    "system_ir",
    "plot_manifest"
  ],
  "properties": {
    "format": { "const": "eng-report-spec-v1" },
    "report_schema_version": { "const": 1 },
    "compiler_version": { "type": "string" },
    "report_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "provenance": {
      "type": "object",
      "required": [
        "schema_count",
        "csv_promotion_count",
        "domain_count",
        "component_count",
        "connection_count",
        "system_count",
        "equation_count",
        "residual_count",
        "environment_dependencies",
        "plot_spec_version"
      ],
      "properties": {
        "environment_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentDependency" }
        }
      }
    },
    "variable_table": { "type": "array" },
    "args_summary": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "schema_summary": { "type": "array" },
    "computed_statistics": { "type": "array" },
    "computed_integrations": { "type": "array" },
    "computed_metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/reportMetric" }
    },
    "validations": {
      "type": "array",
      "items": { "$ref": "#/$defs/reportValidation" }
    },
    "time_alignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeAlignment" }
    },
    "uncertainty": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertainty" }
    },
    "policy_results": { "type": "array" },
    "domain_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/domainSummary" }
    },
    "component_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentSummary" }
    },
    "connection_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionSummary" }
    },
    "system_summary": { "type": "array" },
    "system_ir": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemIr" }
    },
    "plot_manifest": { "type": "object" }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "source_hash", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "source_hash": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertainty": {
      "type": "object",
      "required": [
        "binding",
        "kind",
        "quantity_kind",
        "display_unit",
        "sample_count",
        "propagation_count",
        "propagation",
        "line"
      ],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "propagation_count": { "type": "integer", "minimum": 0 },
        "propagation": {
          "type": "array",
          "items": { "$ref": "#/$defs/uncertaintyPropagationTerm" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertaintyPropagationTerm": {
      "type": "object",
      "required": ["source", "role", "quantity_kind"],
      "properties": {
        "source": { "type": "string" },
        "role": { "type": "string" },
        "quantity_kind": { "type": "string" }
      }
    },
    "reportMetric": {
      "type": "object",
      "required": ["binding", "kind", "left", "right", "quantity_kind", "unit", "value", "sample_count", "status", "line"],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "left": { "type": "string" },
        "right": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "unit": { "type": "string" },
        "value": { "type": "number" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "reportValidation": {
      "type": "object",
      "required": ["expression", "left", "operator", "right", "left_value", "right_value", "unit", "status", "line"],
      "properties": {
        "expression": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "type": "string" },
        "right": { "type": "string" },
        "left_value": { "type": ["number", "null"] },
        "right_value": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "status": { "enum": ["passed", "failed", "unavailable"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "timeAlignment": {
      "type": "object",
      "required": ["left", "right", "axis", "left_count", "right_count", "matched_count", "overlap_start", "overlap_end", "status"],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "axis": { "type": "string" },
        "left_count": { "type": "integer", "minimum": 0 },
        "right_count": { "type": "integer", "minimum": 0 },
        "matched_count": { "type": "integer", "minimum": 0 },
        "overlap_start": { "type": ["number", "null"] },
        "overlap_end": { "type": ["number", "null"] },
        "status": { "enum": ["matched", "overlap", "mismatch"] }
      }
    },
    "domainSummary": {
      "type": "object",
      "required": [
        "name",
        "type_parameters",
        "package",
        "version",
        "line",
        "variable_count",
        "conservation_count",
        "variables",
        "conservations"
      ],
      "properties": {
        "name": { "type": "string" },
        "type_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainTypeParameter" }
        },
        "package": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "conservation_count": { "type": "integer", "minimum": 0 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainVariable" }
        },
        "conservations": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainConservation" }
        }
      }
    },
    "domainTypeParameter": {
      "type": "object",
      "required": ["kind", "name", "display"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "domainVariable": {
      "type": "object",
      "required": [
        "role",
        "name",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "dimension",
        "line"
      ],
      "properties": {
        "role": { "enum": ["across", "through"] },
        "name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainConservation": {
      "type": "object",
      "required": ["text", "status", "line"],
      "properties": {
        "text": { "type": "string" },
        "status": { "const": "recorded" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentSummary": {
      "type": "object",
      "required": ["name", "line", "port_count", "ports"],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "port_count": { "type": "integer", "minimum": 0 },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentPort" }
        }
      }
    },
    "componentPort": {
      "type": "object",
      "required": ["name", "domain", "domain_name", "type_arguments", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "domain_name": { "type": "string" },
        "type_arguments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "enum": [
            "domain_resolved",
            "unknown_domain",
            "generic_arity_mismatch",
            "unvalidated"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "connectionSummary": {
      "type": "object",
      "required": ["left", "right", "domain", "status", "line"],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "domain": { "type": "string" },
        "status": {
          "enum": [
            "domain_compatible",
            "domain_mismatch",
            "medium_mismatch",
            "frame_mismatch",
            "axis_mismatch",
            "domain_parameter_mismatch",
            "unresolved_endpoint"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemIr": {
      "type": "object",
      "required": ["name", "solver_boundary", "solver_plan", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "solver_boundary": { "$ref": "#/$defs/solverBoundary" },
        "solver_plan": { "$ref": "#/$defs/solverPlan" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "solverBoundary": {
      "type": "object",
      "required": [
        "status",
        "reason",
        "parameter_count",
        "state_count",
        "input_count",
        "equation_count",
        "residual_count"
      ],
      "properties": {
        "status": { "enum": ["unsolved", "computed"] },
        "reason": { "type": "string" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "state_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "residual_count": { "type": "integer", "minimum": 0 }
      }
    },
    "solverPlan": {
      "type": "object",
      "required": ["status", "method", "solve_order", "ode_runner", "jacobian_seed"],
      "properties": {
        "status": { "enum": ["metadata_only", "computed"] },
        "method": { "type": "string" },
        "solve_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ode_runner": { "$ref": "#/$defs/odeRunner" },
        "jacobian_seed": {
          "type": "array",
          "items": { "$ref": "#/$defs/jacobianSeed" }
        }
      }
    },
    "odeRunner": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "enum": ["deferred", "computed"] },
        "reason": { "type": "string" }
      }
    },
    "jacobianSeed": {
      "type": "object",
      "required": ["residual", "with_respect_to", "derivative_states", "status"],
      "properties": {
        "residual": { "type": "string" },
        "with_respect_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "const": "symbolic_seed" }
      }
    },
    "equationIr": {
      "type": "object",
      "required": [
        "residual",
        "relation",
        "normalized_residual",
        "status",
        "dependencies",
        "derivative_states",
        "line"
      ],
      "properties": {
        "residual": { "type": "string" },
        "relation": { "const": "eq" },
        "normalized_residual": { "type": "string" },
        "status": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationDependency" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationDependency": {
      "type": "object",
      "required": ["name", "role", "quantity_kind"],
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["parameter", "state", "input"] },
        "quantity_kind": { "type": "string" }
      }
    }
  }
}
