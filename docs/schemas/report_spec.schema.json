{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/report_spec.schema.json",
  "title": "EngLang ReportSpec Artifact",
  "type": "object",
  "required": [
    "format",
    "report_schema_version",
    "compiler_version",
    "report_version",
    "source_path",
    "source_hash",
    "provenance",
    "variable_table",
    "args_summary",
    "arg_values",
    "schema_summary",
    "computed_statistics",
    "computed_integrations",
    "computed_metrics",
    "validations",
    "time_axes",
    "time_alignments",
    "policy_results",
    "domain_summary",
    "component_summary",
    "connection_summary",
    "assembly_summary",
    "component_graph",
    "class_summary",
    "object_summary",
    "system_summary",
    "state_space_vectors",
    "linear_operators",
    "system_ir",
    "plot_manifest"
  ],
  "properties": {
    "format": { "const": "eng-report-spec-v1" },
    "report_schema_version": { "const": 1 },
    "compiler_version": { "type": "string" },
    "report_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "provenance": {
      "type": "object",
      "required": [
        "schema_count",
        "csv_promotion_count",
        "domain_count",
        "component_count",
        "connection_count",
        "assembly_count",
        "class_count",
        "object_count",
        "system_count",
        "equation_count",
        "residual_count",
        "environment_dependencies",
        "plot_spec_version"
      ],
      "properties": {
        "environment_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentDependency" }
        }
      }
    },
    "variable_table": { "type": "array" },
    "args_summary": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "schema_summary": { "type": "array" },
    "computed_statistics": { "type": "array" },
    "computed_integrations": { "type": "array" },
    "computed_metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/reportMetric" }
    },
    "validations": {
      "type": "array",
      "items": { "$ref": "#/$defs/reportValidation" }
    },
    "time_alignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeAlignment" }
    },
    "time_axes": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeAxis" }
    },
    "uncertainty": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertainty" }
    },
    "policy_results": { "type": "array" },
    "domain_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/domainSummary" }
    },
    "component_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentSummary" }
    },
    "connection_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionSummary" }
    },
    "assembly_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/assemblySummary" }
    },
    "component_graph": { "$ref": "#/$defs/componentGraph" },
    "class_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/classSummary" }
    },
    "object_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/classObjectSummary" }
    },
    "system_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemSummary" }
    },
    "state_space_vectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/stateSpaceVector" }
    },
    "linear_operators": {
      "type": "array",
      "items": { "$ref": "#/$defs/linearOperator" }
    },
    "system_ir": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemIr" }
    },
    "plot_manifest": { "type": "object" }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "source_hash", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "source_hash": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertainty": {
      "type": "object",
      "required": [
        "binding",
        "kind",
        "quantity_kind",
        "display_unit",
        "sample_count",
        "propagation_count",
        "propagation",
        "line"
      ],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "propagation_count": { "type": "integer", "minimum": 0 },
        "propagation": {
          "type": "array",
          "items": { "$ref": "#/$defs/uncertaintyPropagationTerm" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertaintyPropagationTerm": {
      "type": "object",
      "required": ["source", "role", "quantity_kind"],
      "properties": {
        "source": { "type": "string" },
        "role": { "type": "string" },
        "quantity_kind": { "type": "string" }
      }
    },
    "reportMetric": {
      "type": "object",
      "required": ["binding", "kind", "left", "right", "quantity_kind", "unit", "value", "sample_count", "alignment_reference", "alignment_status", "alignment_step_status", "status", "line"],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "left": { "type": "string" },
        "right": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "unit": { "type": "string" },
        "value": { "type": "number" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "alignment_reference": { "type": ["string", "null"] },
        "alignment_status": { "type": ["string", "null"] },
        "alignment_step_status": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "reportValidation": {
      "type": "object",
      "required": ["expression", "left", "operator", "right", "left_value", "right_value", "unit", "status", "line"],
      "properties": {
        "expression": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "type": "string" },
        "right": { "type": "string" },
        "left_value": { "type": ["number", "null"] },
        "right_value": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "status": { "enum": ["passed", "failed", "unavailable"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "timeAlignment": {
      "type": "object",
      "required": [
        "left",
        "right",
        "axis",
        "left_count",
        "right_count",
        "matched_count",
        "left_nominal_step",
        "right_nominal_step",
        "left_irregular",
        "right_irregular",
        "step_status",
        "overlap_start",
        "overlap_end",
        "status"
      ],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "axis": { "type": "string" },
        "left_count": { "type": "integer", "minimum": 0 },
        "right_count": { "type": "integer", "minimum": 0 },
        "matched_count": { "type": "integer", "minimum": 0 },
        "left_nominal_step": { "type": ["number", "null"] },
        "right_nominal_step": { "type": ["number", "null"] },
        "left_irregular": { "type": "boolean" },
        "right_irregular": { "type": "boolean" },
        "step_status": { "enum": ["matched", "mismatch", "unavailable"] },
        "overlap_start": { "type": ["number", "null"] },
        "overlap_end": { "type": ["number", "null"] },
        "status": { "enum": ["matched", "overlap", "mismatch"] }
      }
    },
    "timeAxis": {
      "type": "object",
      "required": [
        "name",
        "source_table",
        "source_column",
        "axis",
        "unit",
        "start",
        "end",
        "count",
        "nominal_step",
        "irregular",
        "missing_count"
      ],
      "properties": {
        "name": { "type": "string" },
        "source_table": { "type": "string" },
        "source_column": { "type": "string" },
        "axis": { "type": "string" },
        "unit": { "type": "string" },
        "start": { "type": ["number", "null"] },
        "end": { "type": ["number", "null"] },
        "count": { "type": "integer", "minimum": 0 },
        "nominal_step": { "type": ["number", "null"] },
        "irregular": { "type": "boolean" },
        "missing_count": { "type": "integer", "minimum": 0 }
      }
    },
    "domainSummary": {
      "type": "object",
      "required": [
        "name",
        "type_parameters",
        "package",
        "version",
        "line",
        "variable_count",
        "conservation_count",
        "variables",
        "conservations"
      ],
      "properties": {
        "name": { "type": "string" },
        "type_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainTypeParameter" }
        },
        "package": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "conservation_count": { "type": "integer", "minimum": 0 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainVariable" }
        },
        "conservations": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainConservation" }
        }
      }
    },
    "domainTypeParameter": {
      "type": "object",
      "required": ["kind", "name", "display"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "domainVariable": {
      "type": "object",
      "required": [
        "role",
        "name",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "dimension",
        "line"
      ],
      "properties": {
        "role": { "enum": ["across", "through"] },
        "name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainConservation": {
      "type": "object",
      "required": ["text", "status", "line"],
      "properties": {
        "text": { "type": "string" },
        "status": { "const": "recorded" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentSummary": {
      "type": "object",
      "required": [
        "name",
        "line",
        "port_count",
        "local_expression_count",
        "ports",
        "local_expressions"
      ],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "port_count": { "type": "integer", "minimum": 0 },
        "local_expression_count": { "type": "integer", "minimum": 0 },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentPort" }
        },
        "local_expressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentLocalExpression" }
        }
      }
    },
    "componentPort": {
      "type": "object",
      "required": ["name", "domain", "domain_name", "type_arguments", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "domain_name": { "type": "string" },
        "type_arguments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "enum": [
            "domain_resolved",
            "unknown_domain",
            "generic_arity_mismatch",
            "unvalidated"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentLocalExpression": {
      "type": "object",
      "required": ["name", "expression", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "connectionSummary": {
      "type": "object",
      "required": ["left", "right", "domain", "status", "line"],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "domain": { "type": "string" },
        "status": {
          "enum": [
            "domain_compatible",
            "domain_mismatch",
            "medium_mismatch",
            "frame_mismatch",
            "axis_mismatch",
            "domain_parameter_mismatch",
            "unresolved_endpoint"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "assemblySummary": {
      "type": "object",
      "required": [
        "name",
        "status",
        "line",
        "component_count",
        "port_count",
        "connection_count",
        "component_equation_count",
        "local_expression_count",
        "operator_call_count",
        "predictor_call_count",
        "domain_count",
        "domain_plans",
        "solver_preview",
        "connection_sets",
        "equations",
        "variables",
        "boundary",
        "residual_graph",
        "solver_result"
      ],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "component_count": { "type": "integer", "minimum": 0 },
        "port_count": { "type": "integer", "minimum": 0 },
        "connection_count": { "type": "integer", "minimum": 0 },
        "component_equation_count": { "type": "integer", "minimum": 0 },
        "local_expression_count": { "type": "integer", "minimum": 0 },
        "operator_call_count": { "type": "integer", "minimum": 0 },
        "predictor_call_count": { "type": "integer", "minimum": 0 },
        "domain_count": { "type": "integer", "minimum": 0 },
        "domain_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyDomainPlan" }
        },
        "solver_preview": { "$ref": "#/$defs/assemblySolverPreview" },
        "connection_sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyConnectionSet" }
        },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyEquation" }
        },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyVariable" }
        },
        "boundary": { "$ref": "#/$defs/assemblyBoundary" },
        "residual_graph": { "$ref": "#/$defs/assemblyResidualGraph" },
        "solver_result": { "$ref": "#/$defs/componentSolverResultNullable" }
      }
    },
    "componentSolverResultNullable": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/componentSolverResult" }
      ]
    },
    "componentSolverResult": {
      "type": "object",
      "required": [
        "status",
        "method",
        "reason",
        "residual_norm",
        "iteration_count",
        "convergence_status",
        "variables",
        "residuals",
        "failure_artifact"
      ],
      "properties": {
        "status": { "type": "string" },
        "method": { "type": "string" },
        "reason": { "type": "string" },
        "residual_norm": { "type": "number" },
        "iteration_count": { "type": "integer", "minimum": 0 },
        "convergence_status": { "type": "string" },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSolverVariable" }
        },
        "residuals": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSolverResidual" }
        },
        "failure_artifact": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/componentSolverFailure" }
          ]
        }
      }
    },
    "componentSolverVariable": {
      "type": "object",
      "required": ["name", "role", "value", "unit", "status"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "componentSolverResidual": {
      "type": "object",
      "required": [
        "name",
        "expression",
        "value",
        "unit",
        "normalized_value",
        "scale",
        "scale_policy",
        "status"
      ],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "normalized_value": { "type": "number" },
        "scale": { "type": "number" },
        "scale_policy": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "componentSolverFailure": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "assemblyDomainPlan": {
      "type": "object",
      "required": [
        "domain",
        "connection_set_count",
        "equation_count",
        "variable_count",
        "conservation_status",
        "solver_role"
      ],
      "properties": {
        "domain": { "type": "string" },
        "connection_set_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "conservation_status": { "type": "string" },
        "solver_role": { "type": "string" }
      }
    },
    "assemblySolverPreview": {
      "type": "object",
      "required": [
        "status",
        "method",
        "mixed_algebraic_dynamic",
        "nonlinear_residual",
        "dae_split",
        "delay_history",
        "predictor",
        "external_adapter",
        "limitations"
      ],
      "properties": {
        "status": { "type": "string" },
        "method": { "type": "string" },
        "mixed_algebraic_dynamic": { "type": "string" },
        "nonlinear_residual": { "type": "string" },
        "dae_split": { "type": "string" },
        "delay_history": { "type": "string" },
        "predictor": { "type": "string" },
        "external_adapter": { "type": "string" },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assemblyConnectionSet": {
      "type": "object",
      "required": ["name", "domain", "connection_count", "status", "line", "ports"],
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "connection_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "ports": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assemblyEquation": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "domain",
        "expression",
        "residual",
        "reason",
        "status",
        "line",
        "dependencies"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "domain": { "type": "string" },
        "expression": { "type": "string" },
        "residual": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assemblyVariable": {
      "type": "object",
      "required": ["name", "role", "domain", "source", "status"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "domain": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "assemblyBoundary": {
      "type": "object",
      "required": [
        "state_count",
        "algebraic_count",
        "input_count",
        "output_count",
        "parameter_count",
        "equation_count",
        "unknown_count",
        "balance_status",
        "diagnostic_code"
      ],
      "properties": {
        "state_count": { "type": "integer", "minimum": 0 },
        "algebraic_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "output_count": { "type": "integer", "minimum": 0 },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "unknown_count": { "type": "integer", "minimum": 0 },
        "balance_status": { "type": "string" },
        "diagnostic_code": { "type": ["string", "null"] }
      }
    },
    "assemblyResidualGraph": {
      "type": "object",
      "required": [
        "name",
        "status",
        "solver_plan",
        "residuals",
        "dependencies",
        "algebraic_loops",
        "jacobian_sparsity"
      ],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "solver_plan": { "type": "string" },
        "residuals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyResidualDependency" }
        },
        "algebraic_loops": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "jacobian_sparsity": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyJacobianSeed" }
        }
      }
    },
    "assemblyResidualDependency": {
      "type": "object",
      "required": ["residual", "variable"],
      "properties": {
        "residual": { "type": "string" },
        "variable": { "type": "string" }
      }
    },
    "assemblyJacobianSeed": {
      "type": "object",
      "required": ["residual", "status", "with_respect_to"],
      "properties": {
        "residual": { "type": "string" },
        "status": { "type": "string" },
        "with_respect_to": {
