{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/run_log.schema.json",
  "title": "EngLang Run Log Artifact",
  "type": "object",
  "required": [
    "format",
    "runtime_version",
    "source_path",
    "execution_profile",
    "message_count",
    "messages",
    "profile_diagnostics"
  ],
  "properties": {
    "format": { "const": "eng-run-log-v1" },
    "runtime_version": { "type": "string" },
    "source_path": { "type": "string" },
    "execution_profile": { "enum": ["safe", "normal", "repro"] },
    "message_count": { "type": "integer", "minimum": 0 },
    "messages": {
      "type": "array",
      "items": { "$ref": "#/$defs/runLogMessage" }
    },
    "profile_diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/profileDiagnostic" }
    }
  },
  "$defs": {
    "runLogMessage": {
      "type": "object",
      "required": ["index", "level", "message", "line"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "level": { "enum": ["print", "debug", "info", "warn", "error"] },
        "message": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "profileDiagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "line"],
      "properties": {
        "severity": { "enum": ["warning", "error"] },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
