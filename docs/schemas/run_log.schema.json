{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/run_log.schema.json",
  "title": "EngLang Run Log Artifact",
  "type": "object",
  "required": [
    "format",
    "runtime_version",
    "source_path",
    "working_dir",
    "output_dir",
    "execution_profile",
    "message_count",
    "messages",
    "external_boundary_event_count",
    "external_boundary_events",
    "network_event_count",
    "network_events",
    "cache_event_count",
    "cache_events",
    "profile_diagnostics"
  ],
  "properties": {
    "format": { "const": "eng-run-log-v1" },
    "runtime_version": { "type": "string" },
    "source_path": { "type": "string" },
    "working_dir": { "type": "string" },
    "output_dir": { "type": "string" },
    "execution_profile": { "enum": ["safe", "normal", "repro"] },
    "message_count": { "type": "integer", "minimum": 0 },
    "messages": {
      "type": "array",
      "items": { "$ref": "#/$defs/runLogMessage" }
    },
    "external_boundary_event_count": { "type": "integer", "minimum": 0 },
    "external_boundary_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundaryEvent" }
    },
    "network_event_count": { "type": "integer", "minimum": 0 },
    "network_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundaryEvent" }
    },
    "cache_event_count": { "type": "integer", "minimum": 0 },
    "cache_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundaryEvent" }
    },
    "profile_diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/profileDiagnostic" }
    }
  },
  "$defs": {
    "runLogMessage": {
      "type": "object",
      "required": ["index", "level", "message", "line"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "level": { "enum": ["print", "debug", "info", "warn", "error"] },
        "message": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "boundaryEvent": {
      "type": "object",
      "required": ["kind", "status", "line"],
      "properties": {
        "kind": { "type": "string" },
        "binding": { "type": "string" },
        "owner_kind": { "type": "string" },
        "owner_name": { "type": "string" },
        "command": { "type": "string" },
        "env": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout": { "type": ["string", "null"] },
        "retry": { "type": "integer", "minimum": 0 },
        "attempt_count": { "type": "integer", "minimum": 1 },
        "allow_failure": { "type": "boolean" },
        "timed_out": { "type": "boolean" },
        "url": { "type": "string" },
        "target": { "type": "string" },
        "cache_key_hash": { "type": "string" },
        "cache_path": { "type": "string" },
        "lookup_status": { "type": "string" },
        "response_hash": { "type": ["string", "null"] },
        "expected_output_status": { "type": "string" },
        "stdout_hash": { "type": "string" },
        "stderr_hash": { "type": "string" },
        "status": { "type": "string" },
        "success": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "profileDiagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "line"],
      "properties": {
        "severity": { "enum": ["warning", "error"] },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
