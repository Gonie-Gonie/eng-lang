{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/result.schema.json",
  "title": "EngLang Result Artifact",
  "type": "object",
  "required": [
    "format",
    "result_format_version",
    "runtime_version",
    "compiler_version",
    "bytecode_version",
    "source_path",
    "source_hash",
    "bytecode_hash",
    "numeric_profile",
    "workflow",
    "args_schema",
    "arg_values",
    "object_store",
    "typed_payload",
    "provenance"
  ],
  "properties": {
    "format": { "const": "engres-v1" },
    "result_format_version": { "const": 1 },
    "runtime_version": { "type": "string" },
    "compiler_version": { "type": "string" },
    "bytecode_version": { "const": 1 },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "bytecode_hash": { "type": "string" },
    "numeric_profile": { "type": "string" },
    "workflow": {
      "type": "object",
      "required": ["kind", "arg_name", "arg_type", "return_type"]
    },
    "args_schema": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "object_store": {
      "type": "object",
      "required": ["scalar_count", "table_count", "timeseries_count", "array_count", "objects"]
    },
    "typed_payload": {
      "type": "object",
      "required": ["kind", "status", "result_format", "vm_steps", "statistics", "integrations", "policy_results", "systems", "solver_boundaries", "system_ir"],
      "properties": {
        "solver_boundaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSolverBoundary" }
        },
        "system_ir": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemIr" }
        },
        "uncertainties": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultUncertainty" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "schema_count",
        "csv_promotion_count",
        "system_count",
        "equation_count",
        "residual_count",
        "environment_dependencies",
        "data_hashes",
        "plot_spec_hash",
        "report_spec_hash",
        "schema_hash"
      ],
      "properties": {
        "environment_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentDependency" }
        }
      }
    }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultSolverBoundary": {
      "type": "object",
      "required": [
        "system",
        "status",
        "reason",
        "parameter_count",
        "state_count",
        "input_count",
        "equation_count",
        "residual_count",
        "line"
      ],
      "properties": {
        "system": { "type": "string" },
        "status": { "enum": ["unsolved", "computed"] },
        "reason": { "type": "string" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "state_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "residual_count": { "type": "integer", "minimum": 0 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultUncertainty": {
      "type": "object",
      "required": [
        "binding",
        "kind",
        "quantity_kind",
        "display_unit",
        "sample_count",
        "propagation_count",
        "propagation",
        "samples",
        "status",
        "line"
      ],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "propagation_count": { "type": "integer", "minimum": 0 },
        "propagation": {
          "type": "array",
          "items": { "$ref": "#/$defs/uncertaintyPropagationTerm" }
        },
        "samples": {
          "type": "array",
          "items": { "type": "number" }
        },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertaintyPropagationTerm": {
      "type": "object",
      "required": ["source", "role", "quantity_kind"],
      "properties": {
        "source": { "type": "string" },
        "role": { "type": "string" },
        "quantity_kind": { "type": "string" }
      }
    },
    "resultSystemIr": {
      "type": "object",
      "required": ["name", "solver_plan", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "solver_plan": { "$ref": "#/$defs/solverPlan" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "solverPlan": {
      "type": "object",
      "required": ["status", "method", "solve_order", "ode_runner", "jacobian_seed"],
      "properties": {
        "status": { "enum": ["metadata_only", "computed"] },
        "method": { "type": "string" },
        "solve_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ode_runner": { "$ref": "#/$defs/odeRunner" },
        "jacobian_seed": {
          "type": "array",
          "items": { "$ref": "#/$defs/jacobianSeed" }
        }
      }
    },
    "odeRunner": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "enum": ["deferred", "computed"] },
        "reason": { "type": "string" }
      }
    },
    "jacobianSeed": {
      "type": "object",
      "required": ["residual", "with_respect_to", "derivative_states", "status"],
      "properties": {
        "residual": { "type": "string" },
        "with_respect_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "const": "symbolic_seed" }
      }
    },
    "equationIr": {
      "type": "object",
      "required": [
        "residual",
        "relation",
        "normalized_residual",
        "status",
        "dependencies",
        "derivative_states",
        "line"
      ],
      "properties": {
        "residual": { "type": "string" },
        "relation": { "const": "eq" },
        "normalized_residual": { "type": "string" },
        "status": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationDependency" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationDependency": {
      "type": "object",
      "required": ["name", "role", "quantity_kind"],
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["parameter", "state", "input"] },
        "quantity_kind": { "type": "string" }
      }
    }
  }
}
