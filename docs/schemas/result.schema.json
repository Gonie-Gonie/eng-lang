{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/result.schema.json",
  "title": "EngLang Result Artifact",
  "type": "object",
  "required": [
    "format",
    "result_format_version",
    "runtime_version",
    "compiler_version",
    "bytecode_version",
    "source_path",
    "source_hash",
    "bytecode_hash",
    "numeric_profile",
    "entry",
    "args_schema",
    "object_store",
    "typed_payload",
    "provenance"
  ],
  "properties": {
    "format": { "const": "engres-v1" },
    "result_format_version": { "const": 1 },
    "runtime_version": { "type": "string" },
    "compiler_version": { "type": "string" },
    "bytecode_version": { "const": 1 },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "bytecode_hash": { "type": "string" },
    "numeric_profile": { "type": "string" },
    "entry": {
      "type": "object",
      "required": ["kind", "name", "arg_name", "arg_type", "return_type"]
    },
    "args_schema": { "type": "array" },
    "object_store": {
      "type": "object",
      "required": ["scalar_count", "table_count", "timeseries_count", "array_count", "objects"]
    },
    "typed_payload": {
      "type": "object",
      "required": ["kind", "status", "result_format", "vm_steps", "statistics", "integrations", "policy_results", "systems", "solver_boundaries", "system_ir"],
      "properties": {
        "solver_boundaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSolverBoundary" }
        },
        "system_ir": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemIr" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "schema_count",
        "csv_promotion_count",
        "system_count",
        "equation_count",
        "residual_count",
        "data_hashes",
        "plot_spec_hash",
        "report_spec_hash",
        "schema_hash"
      ]
    }
  },
  "$defs": {
    "resultSolverBoundary": {
      "type": "object",
      "required": [
        "system",
        "status",
        "reason",
        "parameter_count",
        "state_count",
        "input_count",
        "equation_count",
        "residual_count",
        "line"
      ],
      "properties": {
        "system": { "type": "string" },
        "status": { "const": "unsolved" },
        "reason": { "type": "string" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "state_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "residual_count": { "type": "integer", "minimum": 0 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultSystemIr": {
      "type": "object",
      "required": ["name", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationIr": {
      "type": "object",
      "required": [
        "residual",
        "relation",
        "normalized_residual",
        "status",
        "dependencies",
        "derivative_states",
        "line"
      ],
      "properties": {
        "residual": { "type": "string" },
        "relation": { "const": "eq" },
        "normalized_residual": { "type": "string" },
        "status": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationDependency" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationDependency": {
      "type": "object",
      "required": ["name", "role", "quantity_kind"],
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["parameter", "state", "input"] },
        "quantity_kind": { "type": "string" }
      }
    }
  }
}
