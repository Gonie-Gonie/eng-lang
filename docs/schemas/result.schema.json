{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/result.schema.json",
  "title": "EngLang Result Artifact",
  "type": "object",
  "required": [
    "format",
    "result_format_version",
    "runtime_version",
    "compiler_version",
    "bytecode_version",
    "source_path",
    "source_hash",
    "bytecode_hash",
    "numeric_profile",
    "execution_profile",
    "workflow",
    "args_schema",
    "arg_values",
    "object_store",
    "typed_payload",
    "provenance"
  ],
  "properties": {
    "format": { "const": "engres-v1" },
    "result_format_version": { "const": 1 },
    "runtime_version": { "type": "string" },
    "compiler_version": { "type": "string" },
    "bytecode_version": { "const": 1 },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "bytecode_hash": { "type": "string" },
    "numeric_profile": { "type": "string" },
    "execution_profile": { "enum": ["safe", "normal", "repro"] },
    "workflow": {
      "type": "object",
      "required": ["kind", "arg_name", "arg_type", "return_type"]
    },
    "args_schema": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "object_store": {
      "type": "object",
      "required": ["scalar_count", "table_count", "timeseries_count", "array_count", "objects"]
    },
    "typed_payload": {
      "type": "object",
      "required": ["kind", "status", "result_format", "vm_steps", "statistics", "integrations", "metrics", "validations", "time_axes", "time_alignments", "policy_results", "systems", "component_solutions", "solver_boundaries", "system_ir"],
      "properties": {
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultMetric" }
        },
        "validations": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultValidation" }
        },
        "time_alignments": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeAlignment" }
        },
        "time_axes": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeAxis" }
        },
        "systems": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemSummary" }
        },
        "solver_boundaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSolverBoundary" }
        },
        "component_solutions": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSolution" }
        },
        "system_ir": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemIr" }
        },
        "uncertainties": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultUncertainty" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "schema_count",
        "csv_promotion_count",
        "system_count",
        "equation_count",
        "residual_count",
        "component_solution_count",
        "environment_dependencies",
        "profile_diagnostics",
        "data_hashes",
        "plot_spec_hash",
        "report_spec_hash",
        "schema_hash"
      ],
      "properties": {
        "environment_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentDependency" }
        },
        "profile_diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileDiagnostic" }
        }
      }
    }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "source_hash", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "source_hash": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "profileDiagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "line"],
      "properties": {
        "severity": { "enum": ["warning", "error"] },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultMetric": {
      "type": "object",
      "required": ["binding", "kind", "left", "right", "quantity_kind", "unit", "value", "sample_count", "alignment_reference", "alignment_status", "alignment_step_status", "status", "line"],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "left": { "type": "string" },
        "right": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "unit": { "type": "string" },
        "value": { "type": "number" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "alignment_reference": { "type": ["string", "null"] },
        "alignment_status": { "type": ["string", "null"] },
        "alignment_step_status": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultValidation": {
      "type": "object",
      "required": ["expression", "left", "operator", "right", "left_value", "right_value", "unit", "status", "line"],
      "properties": {
        "expression": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "type": "string" },
        "right": { "type": "string" },
        "left_value": { "type": ["number", "null"] },
        "right_value": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "status": { "enum": ["passed", "failed", "unavailable"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "timeAlignment": {
      "type": "object",
      "required": [
        "left",
        "right",
        "axis",
        "left_count",
        "right_count",
        "matched_count",
        "left_nominal_step",
        "right_nominal_step",
        "left_irregular",
        "right_irregular",
        "step_status",
        "overlap_start",
        "overlap_end",
        "status"
      ],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "axis": { "type": "string" },
        "left_count": { "type": "integer", "minimum": 0 },
        "right_count": { "type": "integer", "minimum": 0 },
        "matched_count": { "type": "integer", "minimum": 0 },
        "left_nominal_step": { "type": ["number", "null"] },
        "right_nominal_step": { "type": ["number", "null"] },
        "left_irregular": { "type": "boolean" },
        "right_irregular": { "type": "boolean" },
        "step_status": { "enum": ["matched", "mismatch", "unavailable"] },
        "overlap_start": { "type": ["number", "null"] },
        "overlap_end": { "type": ["number", "null"] },
        "status": { "enum": ["matched", "overlap", "mismatch"] }
      }
    },
    "timeAxis": {
      "type": "object",
      "required": [
        "name",
        "source_table",
        "source_column",
        "axis",
        "unit",
        "start",
        "end",
        "count",
        "nominal_step",
        "irregular",
        "missing_count"
      ],
      "properties": {
        "name": { "type": "string" },
        "source_table": { "type": "string" },
        "source_column": { "type": "string" },
        "axis": { "type": "string" },
        "unit": { "type": "string" },
        "start": { "type": ["number", "null"] },
        "end": { "type": ["number", "null"] },
        "count": { "type": "integer", "minimum": 0 },
        "nominal_step": { "type": ["number", "null"] },
        "irregular": { "type": "boolean" },
        "missing_count": { "type": "integer", "minimum": 0 }
      }
    },
    "componentSolution": {
      "type": "object",
      "required": [
        "assembly",
        "status",
        "method",
        "reason",
        "equation_count",
        "unknown_count",
        "residual_norm",
        "iteration_count",
        "convergence_status",
        "variables",
        "residuals",
        "failure_artifact"
      ],
      "properties": {
        "assembly": { "type": "string" },
        "status": { "type": "string" },
        "method": { "type": "string" },
        "reason": { "type": "string" },
        "equation_count": { "type": "integer", "minimum": 0 },
        "unknown_count": { "type": "integer", "minimum": 0 },
        "residual_norm": { "type": "number" },
        "iteration_count": { "type": "integer", "minimum": 0 },
        "convergence_status": { "type": "string" },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentSolutionVariable" }
        },
        "residuals": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentResidualEvaluation" }
        },
        "failure_artifact": {
          "type": ["object", "null"],
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "componentSolutionVariable": {
      "type": "object",
      "required": ["name", "role", "value", "unit", "status"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "componentResidualEvaluation": {
      "type": "object",
      "required": ["name", "expression", "value", "status"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "resultSystemSummary": {
      "type": "object",
      "required": ["name", "variable_count", "equations", "residuals"],
      "properties": {
        "name": { "type": "string" },
        "variable_count": { "type": "integer", "minimum": 0 },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemEquation" }
        },
        "residuals": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultSystemResidual" }
        },
        "solver_result": { "$ref": "#/$defs/resultSystemSolution" }
      }
    },
    "resultSystemEquation": {
      "type": "object",
      "required": [
        "left",
        "relation",
        "right",
        "left_dimension",
        "right_dimension",
        "residual",
        "status"
      ],
      "properties": {
        "left": { "type": "string" },
        "relation": { "type": "string" },
        "right": { "type": "string" },
        "left_dimension": { "type": "string" },
        "right_dimension": { "type": "string" },
        "residual": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "resultSystemResidual": {
      "type": "object",
      "required": ["name", "expression", "dimension"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "dimension": { "type": "string" }
      }
    },
    "resultSystemSolution": {
      "type": "object",
      "required": [
        "status",
        "binding",
        "method",
        "reason",
        "state",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "time_unit",
        "duration",
        "time_step",
        "step_count",
        "initial_value",
        "final_value",
        "canonical_initial_value",
        "canonical_final_value",
        "points"
      ],
      "properties": {
        "status": { "enum": ["computed"] },
        "binding": { "type": ["string", "null"] },
        "method": { "type": "string" },
        "reason": { "type": "string" },
        "state": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "time_unit": { "type": "string" },
        "duration": { "type": "number" },
        "time_step": { "type": "number" },
        "step_count": { "type": "integer", "minimum": 0 },
        "initial_value": { "type": "number" },
        "final_value": { "type": "number" },
        "canonical_initial_value": { "type": "number" },
        "canonical_final_value": { "type": "number" },
        "points": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultPoint" }
        }
      }
    },
    "resultPoint": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "resultSolverBoundary": {
      "type": "object",
      "required": [
        "system",
        "status",
        "reason",
        "parameter_count",
        "state_count",
        "input_count",
        "equation_count",
        "residual_count",
        "line"
      ],
      "properties": {
        "system": { "type": "string" },
        "status": { "enum": ["unsolved", "computed"] },
        "reason": { "type": "string" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "state_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "residual_count": { "type": "integer", "minimum": 0 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "resultUncertainty": {
      "type": "object",
      "required": [
        "binding",
        "kind",
        "quantity_kind",
        "display_unit",
        "sample_count",
        "propagation_count",
        "propagation",
        "samples",
        "status",
        "line"
      ],
      "properties": {
        "binding": { "type": "string" },
        "kind": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "sample_count": { "type": "integer", "minimum": 0 },
        "propagation_count": { "type": "integer", "minimum": 0 },
        "propagation": {
          "type": "array",
          "items": { "$ref": "#/$defs/uncertaintyPropagationTerm" }
        },
        "samples": {
          "type": "array",
          "items": { "type": "number" }
        },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "uncertaintyPropagationTerm": {
      "type": "object",
      "required": ["source", "role", "quantity_kind"],
      "properties": {
        "source": { "type": "string" },
        "role": { "type": "string" },
        "quantity_kind": { "type": "string" }
      }
    },
    "resultSystemIr": {
      "type": "object",
      "required": ["name", "solver_plan", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "solver_plan": { "$ref": "#/$defs/solverPlan" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "solverPlan": {
      "type": "object",
      "required": ["status", "method", "solve_order", "ode_runner", "jacobian_seed"],
      "properties": {
        "status": { "enum": ["metadata_only", "computed"] },
        "method": { "type": "string" },
        "solve_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ode_runner": { "$ref": "#/$defs/odeRunner" },
        "jacobian_seed": {
          "type": "array",
          "items": { "$ref": "#/$defs/jacobianSeed" }
        }
      }
    },
    "odeRunner": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "enum": ["deferred", "computed"] },
        "reason": { "type": "string" }
      }
    },
    "jacobianSeed": {
      "type": "object",
      "required": ["residual", "with_respect_to", "derivative_states", "status"],
      "properties": {
        "residual": { "type": "string" },
        "with_respect_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "const": "symbolic_seed" }
      }
    },
    "equationIr": {
      "type": "object",
      "required": [
        "residual",
        "relation",
        "normalized_residual",
        "status",
        "dependencies",
        "derivative_states",
        "line"
      ],
      "properties": {
        "residual": { "type": "string" },
        "relation": { "const": "eq" },
        "normalized_residual": { "type": "string" },
        "status": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationDependency" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationDependency": {
      "type": "object",
      "required": ["name", "role", "quantity_kind"],
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["parameter", "state", "input"] },
        "quantity_kind": { "type": "string" }
      }
    }
  }
}
