{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/static_run_plan.schema.json",
  "title": "EngLang Static Run Plan Artifact",
  "type": "object",
  "required": [
    "format",
    "runtime_version",
    "source_path",
    "source_hash",
    "execution_profile",
    "execution_stage",
    "status",
    "rerun_status",
    "rerun_decision",
    "graph"
  ],
  "properties": {
    "format": { "const": "eng-static-run-plan-v2" },
    "runtime_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "execution_profile": { "enum": ["safe", "normal", "repro"] },
    "execution_stage": { "const": "pre_execution" },
    "status": { "const": "ready" },
    "rerun_status": { "enum": ["scheduled", "skipped"] },
    "rerun_decision": { "$ref": "#/$defs/rerunDecision" },
    "graph": {
      "type": "object",
      "required": ["node_count", "edge_count", "nodes", "edges"],
      "properties": {
        "node_count": { "type": "integer", "minimum": 1 },
        "edge_count": { "type": "integer", "minimum": 0 },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/runPlanNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/runPlanEdge" }
        }
      }
    }
  },
  "$defs": {
    "rerunDecision": {
      "type": "object",
      "required": ["decision", "reason"],
      "properties": {
        "decision": { "enum": ["run", "skip"] },
        "reason": { "type": "string" },
        "prior_input_hash": { "type": ["string", "null"] }
      }
    },
    "runPlanNode": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "label",
        "status",
        "phase",
        "risk",
        "risk_category",
        "risk_severity",
        "rerun_status",
        "line",
        "source_span",
        "rerun_decision",
        "outputs"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "label": { "type": "string" },
        "status": { "enum": ["loaded", "declared", "resolved"] },
        "phase": { "const": "static" },
        "risk": { "enum": ["low", "medium", "high"] },
        "risk_category": { "$ref": "#/$defs/reviewRiskCategory" },
        "risk_severity": { "enum": ["info", "warning", "error"] },
        "rerun_status": { "enum": ["scheduled", "skipped"] },
        "line": { "type": "integer", "minimum": 0 },
        "source_span": {
          "type": "object",
          "required": ["line"],
          "properties": {
            "line": { "type": "integer", "minimum": 0 }
          }
        },
        "rerun_decision": { "$ref": "#/$defs/rerunDecision" },
        "outputs": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "runPlanEdge": {
      "type": "object",
      "required": ["from", "to", "kind"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "kind": { "type": "string" }
      }
    },
    "reviewRiskCategory": {
      "enum": [
        "data_quality",
        "unit_or_quantity",
        "external_boundary",
        "reproducibility",
        "uncertainty",
        "solver_or_numeric",
        "side_effect",
        "claim_boundary"
      ]
    }
  }
}
