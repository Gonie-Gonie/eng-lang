{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/review.schema.json",
  "title": "EngLang Review Artifact",
  "type": "object",
  "required": [
    "format",
    "review_schema_version",
    "compiler_version",
    "source_path",
    "source_hash",
    "syntax_summary",
    "variable_table",
    "warning_list",
    "plot_manifest",
    "args_summary",
    "arg_values",
    "environment_dependencies",
    "prints",
    "csv_exports",
    "writes",
    "file_operations",
    "domain_summary",
    "component_summary",
    "connection_summary",
    "schema_summary",
    "system_summary",
    "system_ir"
  ],
  "properties": {
    "format": { "const": "eng-review-preview-1" },
    "review_schema_version": { "const": 1 },
    "compiler_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "syntax_summary": {
      "type": "object",
      "required": [
        "scripts",
        "schemas",
        "systems",
        "domains",
        "components",
        "ports",
        "connections",
        "equations",
        "fast_bindings"
      ]
    },
    "variable_table": { "type": "array" },
    "warning_list": { "type": "array" },
    "plot_manifest": { "type": "object" },
    "args_summary": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "environment_dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/environmentDependency" }
    },
    "prints": {
      "type": "array",
      "items": { "$ref": "#/$defs/print" }
    },
    "csv_exports": {
      "type": "array",
      "items": { "$ref": "#/$defs/csvExport" }
    },
    "writes": {
      "type": "array",
      "items": { "$ref": "#/$defs/writeOutput" }
    },
    "file_operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/fileOperation" }
    },
    "domain_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/domainSummary" }
    },
    "component_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentSummary" }
    },
    "connection_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionSummary" }
    },
    "schema_summary": { "type": "array" },
    "system_summary": { "type": "array" },
    "system_ir": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemIr" }
    }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "source_hash", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "source_hash": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "formatField": {
      "type": "object",
      "required": [
        "expression",
        "quantity_kind",
        "display_unit",
        "requested_unit",
        "precision",
        "line"
      ],
      "properties": {
        "expression": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "requested_unit": { "type": ["string", "null"] },
        "precision": { "type": ["integer", "null"], "minimum": 0 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "print": {
      "type": "object",
      "required": ["template", "line", "fields"],
      "properties": {
        "template": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/formatField" }
        }
      }
    },
    "csvExport": {
      "type": "object",
      "required": ["source", "format", "path", "line", "fields"],
      "properties": {
        "source": { "const": "summary" },
        "format": { "const": "csv" },
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/csvExportField" }
        }
      }
    },
    "csvExportField": {
      "allOf": [
        { "$ref": "#/$defs/formatField" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" }
          }
        }
      ]
    },
    "writeOutput": {
      "type": "object",
      "required": ["format", "path", "expression", "quantity_kind", "display_unit", "line"],
      "properties": {
        "format": { "enum": ["text", "json"] },
        "path": { "type": "string" },
        "expression": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "fileOperation": {
      "type": "object",
      "required": ["operation", "source", "destination", "line"],
      "properties": {
        "operation": { "enum": ["copy", "move", "delete"] },
        "source": { "type": "string" },
        "destination": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemIr": {
      "type": "object",
      "required": ["name", "solver_boundary", "solver_plan", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "solver_boundary": { "$ref": "#/$defs/solverBoundary" },
        "solver_plan": { "$ref": "#/$defs/solverPlan" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainSummary": {
      "type": "object",
      "required": [
        "name",
        "type_parameters",
        "package",
        "version",
        "line",
        "variable_count",
        "conservation_count",
        "variables",
        "conservations"
      ],
      "properties": {
        "name": { "type": "string" },
        "type_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainTypeParameter" }
        },
        "package": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "conservation_count": { "type": "integer", "minimum": 0 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainVariable" }
        },
        "conservations": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainConservation" }
        }
      }
    },
    "domainTypeParameter": {
      "type": "object",
      "required": ["kind", "name", "display"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "domainVariable": {
      "type": "object",
      "required": [
        "role",
        "name",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "dimension",
        "line"
      ],
      "properties": {
        "role": { "enum": ["across", "through"] },
        "name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainConservation": {
      "type": "object",
      "required": ["text", "status", "line"],
      "properties": {
        "text": { "type": "string" },
        "status": { "const": "recorded" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentSummary": {
      "type": "object",
      "required": ["name", "line", "port_count", "ports"],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "port_count": { "type": "integer", "minimum": 0 },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentPort" }
        }
      }
    },
    "componentPort": {
      "type": "object",
      "required": ["name", "domain", "domain_name", "type_arguments", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "domain_name": { "type": "string" },
        "type_arguments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "enum": [
            "domain_resolved",
            "unknown_domain",
            "generic_arity_mismatch",
            "unvalidated"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "connectionSummary": {
      "type": "object",
      "required": ["left", "right", "domain", "status", "line"],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "domain": { "type": "string" },
        "status": {
          "enum": [
            "domain_compatible",
            "domain_mismatch",
            "medium_mismatch",
            "frame_mismatch",
            "axis_mismatch",
            "domain_parameter_mismatch",
            "unresolved_endpoint"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "solverBoundary": {
      "type": "object",
      "required": [
        "status",
        "reason",
        "parameter_count",
        "state_count",
        "input_count",
        "equation_count",
        "residual_count"
      ],
      "properties": {
        "status": { "const": "unsolved" },
        "reason": { "type": "string" },
        "parameter_count": { "type": "integer", "minimum": 0 },
        "state_count": { "type": "integer", "minimum": 0 },
        "input_count": { "type": "integer", "minimum": 0 },
        "equation_count": { "type": "integer", "minimum": 0 },
        "residual_count": { "type": "integer", "minimum": 0 }
      }
    },
    "solverPlan": {
      "type": "object",
      "required": ["status", "method", "solve_order", "ode_runner", "jacobian_seed"],
      "properties": {
        "status": { "const": "metadata_only" },
        "method": { "type": "string" },
        "solve_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ode_runner": { "$ref": "#/$defs/odeRunner" },
        "jacobian_seed": {
          "type": "array",
          "items": { "$ref": "#/$defs/jacobianSeed" }
        }
      }
    },
    "odeRunner": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "const": "deferred" },
        "reason": { "type": "string" }
      }
    },
    "jacobianSeed": {
      "type": "object",
      "required": ["residual", "with_respect_to", "derivative_states", "status"],
      "properties": {
        "residual": { "type": "string" },
        "with_respect_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "const": "symbolic_seed" }
      }
    },
    "equationIr": {
      "type": "object",
      "required": [
        "residual",
        "relation",
        "normalized_residual",
        "status",
        "dependencies",
        "derivative_states",
        "line"
      ],
      "properties": {
        "residual": { "type": "string" },
        "relation": { "const": "eq" },
        "normalized_residual": { "type": "string" },
        "status": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationDependency" }
        },
        "derivative_states": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "equationDependency": {
      "type": "object",
      "required": ["name", "role", "quantity_kind"],
      "properties": {
        "name": { "type": "string" },
        "role": { "enum": ["parameter", "state", "input"] },
        "quantity_kind": { "type": "string" }
      }
    }
  }
}
