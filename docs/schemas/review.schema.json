{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/review.schema.json",
  "title": "EngLang Review Artifact",
  "type": "object",
  "required": [
    "format",
    "review_schema_version",
    "compiler_version",
    "source_path",
    "source_hash",
    "syntax_summary",
    "variable_table",
    "warning_list",
    "plot_manifest",
    "args_summary",
    "arg_values",
    "environment_dependencies",
    "prints",
    "csv_exports",
    "writes",
    "file_operations",
    "process_runs",
    "tests",
    "simulation_requests",
    "domain_summary",
    "component_summary",
    "connection_summary",
    "assembly_summary",
    "component_graph",
    "class_summary",
    "object_summary",
    "schema_summary",
    "system_summary",
    "system_ir"
  ],
  "properties": {
    "format": { "const": "eng-review-preview-1" },
    "review_schema_version": { "const": 1 },
    "compiler_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "syntax_summary": {
      "type": "object",
      "required": [
        "scripts",
        "schemas",
        "systems",
        "domains",
        "components",
        "ports",
        "connections",
        "equations",
        "fast_bindings",
        "tests"
      ]
    },
    "variable_table": { "type": "array" },
    "warning_list": { "type": "array" },
    "plot_manifest": { "type": "object" },
    "args_summary": { "type": "array" },
    "arg_values": {
      "type": "array",
      "items": { "$ref": "#/$defs/argValue" }
    },
    "environment_dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/environmentDependency" }
    },
    "prints": {
      "type": "array",
      "items": { "$ref": "#/$defs/print" }
    },
    "csv_exports": {
      "type": "array",
      "items": { "$ref": "#/$defs/csvExport" }
    },
    "writes": {
      "type": "array",
      "items": { "$ref": "#/$defs/writeOutput" }
    },
    "file_operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/fileOperation" }
    },
    "process_runs": {
      "type": "array",
      "items": { "$ref": "#/$defs/processRun" }
    },
    "tests": {
      "type": "array",
      "items": { "$ref": "#/$defs/testBlock" }
    },
    "simulation_requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/simulationRequest" }
    },
    "domain_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/domainSummary" }
    },
    "component_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentSummary" }
    },
    "connection_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionSummary" }
    },
    "assembly_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/assemblySummary" }
    },
    "component_graph": { "$ref": "#/$defs/componentGraph" },
    "class_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/classSummary" }
    },
    "object_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/classObjectSummary" }
    },
    "schema_summary": { "type": "array" },
    "system_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemSummary" }
    },
    "system_ir": {
      "type": "array",
      "items": { "$ref": "#/$defs/systemIr" }
    }
  },
  "$defs": {
    "argValue": {
      "type": "object",
      "required": ["name", "type", "value", "source", "required", "line"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "source": { "enum": ["default", "cli"] },
        "required": { "type": "boolean" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentDependency": {
      "type": "object",
      "required": ["name", "kind", "expression", "resolved_value", "source_hash", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "expression": { "type": "string" },
        "resolved_value": { "type": "string" },
        "source_hash": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "formatField": {
      "type": "object",
      "required": [
        "expression",
        "quantity_kind",
        "display_unit",
        "requested_unit",
        "precision",
        "line"
      ],
      "properties": {
        "expression": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "requested_unit": { "type": ["string", "null"] },
        "precision": { "type": ["integer", "null"], "minimum": 0 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "print": {
      "type": "object",
      "required": ["level", "template", "line", "fields"],
      "properties": {
        "level": { "enum": ["print", "debug", "info", "warn", "error"] },
        "template": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/formatField" }
        }
      }
    },
    "csvExport": {
      "type": "object",
      "required": ["source", "format", "path", "line", "fields"],
      "properties": {
        "source": { "const": "summary" },
        "format": { "const": "csv" },
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/csvExportField" }
        }
      }
    },
    "csvExportField": {
      "allOf": [
        { "$ref": "#/$defs/formatField" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" }
          }
        }
      ]
    },
    "writeOutput": {
      "type": "object",
      "required": ["format", "path", "expression", "quantity_kind", "display_unit", "line"],
      "properties": {
        "format": { "enum": ["text", "json"] },
        "path": { "type": "string" },
        "expression": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "fileOperation": {
      "type": "object",
      "required": ["operation", "source", "destination", "line"],
      "properties": {
        "operation": { "enum": ["copy", "move", "delete"] },
        "source": { "type": "string" },
        "destination": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "processRun": {
      "type": "object",
      "required": ["binding", "command", "line"],
      "properties": {
        "binding": { "type": "string" },
        "command": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "testBlock": {
      "type": "object",
      "required": ["name", "line", "assertions", "goldens"],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assertion" }
        },
        "goldens": {
          "type": "array",
          "items": { "$ref": "#/$defs/goldenCheck" }
        }
      }
    },
    "simulationRequest": {
      "type": "object",
      "required": ["binding", "system", "solver", "time_grid", "inputs", "line"],
      "properties": {
        "binding": { "type": "string" },
        "system": { "type": "string" },
        "solver": { "type": "string" },
        "time_grid": { "$ref": "#/$defs/simulationTimeGrid" },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/simulationInputBinding" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "simulationTimeGrid": {
      "type": "object",
      "required": ["status", "timestep_s", "duration_s", "step_count"],
      "properties": {
        "status": { "type": "string" },
        "timestep_s": { "type": ["number", "null"] },
        "duration_s": { "type": ["number", "null"] },
        "step_count": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "simulationInputBinding": {
      "type": "object",
      "required": ["name", "source", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "assertion": {
      "type": "object",
      "required": ["left", "operator", "right", "tolerance", "line"],
      "properties": {
        "left": { "type": "string" },
        "operator": { "enum": ["==", "!=", ">", ">=", "<", "<="] },
        "right": { "type": "string" },
        "tolerance": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "goldenCheck": {
      "type": "object",
      "required": ["artifact", "expected", "line"],
      "properties": {
        "artifact": { "type": "string" },
        "expected": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "classSummary": {
      "type": "object",
      "required": [
        "name",
        "line",
        "field_count",
        "validation_count",
        "method_count",
        "status",
        "fields",
        "validations",
        "methods"
      ],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "field_count": { "type": "integer", "minimum": 0 },
        "validation_count": { "type": "integer", "minimum": 0 },
        "method_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/classField" }
        },
        "validations": {
          "type": "array",
          "items": { "$ref": "#/$defs/classValidation" }
        },
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/classMethod" }
        }
      }
    },
    "classField": {
      "type": "object",
      "required": [
        "name",
        "type_name",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "dimension",
        "default",
        "required",
        "status",
        "line"
      ],
      "properties": {
        "name": { "type": "string" },
        "type_name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "default": { "type": ["string", "null"] },
        "required": { "type": "boolean" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "classValidation": {
      "type": "object",
      "required": ["expression", "left", "operator", "right", "status", "line"],
      "properties": {
        "expression": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "type": "string" },
        "right": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "classMethod": {
      "type": "object",
      "required": [
        "name",
        "return_type",
        "return_quantity_kind",
        "return_display_unit",
        "return_canonical_unit",
        "expression",
        "status",
        "line"
      ],
      "properties": {
        "name": { "type": "string" },
        "return_type": { "type": "string" },
        "return_quantity_kind": { "type": "string" },
        "return_display_unit": { "type": "string" },
        "return_canonical_unit": { "type": "string" },
        "expression": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "classObjectSummary": {
      "type": "object",
      "required": [
        "name",
        "class_name",
        "source_object",
        "construction",
        "line",
        "field_count",
        "validation_count",
        "status",
        "fields",
        "validations"
      ],
      "properties": {
        "name": { "type": "string" },
        "class_name": { "type": "string" },
        "source_object": { "type": ["string", "null"] },
        "construction": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "field_count": { "type": "integer", "minimum": 0 },
        "validation_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/classObjectField" }
        },
        "validations": {
          "type": "array",
          "items": { "$ref": "#/$defs/classObjectValidation" }
        }
      }
    },
    "classObjectField": {
      "type": "object",
      "required": ["name", "expression", "quantity_kind", "display_unit", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "classObjectValidation": {
      "type": "object",
      "required": [
        "expression",
        "left",
        "operator",
        "right",
        "left_value",
        "right_value",
        "unit",
        "status",
        "line"
      ],
      "properties": {
        "expression": { "type": "string" },
        "left": { "type": "string" },
        "operator": { "type": "string" },
        "right": { "type": "string" },
        "left_value": { "type": ["string", "null"] },
        "right_value": { "type": ["string", "null"] },
        "unit": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemSummary": {
      "type": "object",
      "required": ["name", "line", "variables", "equations", "residuals"],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/systemVariable" }
        },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/systemEquation" }
        },
        "residuals": {
          "type": "array",
          "items": { "$ref": "#/$defs/systemResidual" }
        }
      }
    },
    "systemVariable": {
      "type": "object",
      "required": [
        "role",
        "name",
        "quantity_kind",
        "display_unit",
        "dimension",
        "initial_value",
        "line"
      ],
      "properties": {
        "role": { "type": "string" },
        "name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "initial_value": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemEquation": {
      "type": "object",
      "required": [
        "left",
        "relation",
        "right",
        "left_dimension",
        "right_dimension",
        "residual",
        "status",
        "line"
      ],
      "properties": {
        "left": { "type": "string" },
        "relation": { "type": "string" },
        "right": { "type": "string" },
        "left_dimension": { "type": "string" },
        "right_dimension": { "type": "string" },
        "residual": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemResidual": {
      "type": "object",
      "required": ["name", "expression", "dimension", "line"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "dimension": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "systemIr": {
      "type": "object",
      "required": ["name", "solver_boundary", "solver_plan", "equations", "line"],
      "properties": {
        "name": { "type": "string" },
        "solver_boundary": { "$ref": "#/$defs/solverBoundary" },
        "solver_plan": { "$ref": "#/$defs/solverPlan" },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/equationIr" }
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainSummary": {
      "type": "object",
      "required": [
        "name",
        "type_parameters",
        "package",
        "version",
        "line",
        "variable_count",
        "conservation_count",
        "variables",
        "conservations"
      ],
      "properties": {
        "name": { "type": "string" },
        "type_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainTypeParameter" }
        },
        "package": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 },
        "variable_count": { "type": "integer", "minimum": 0 },
        "conservation_count": { "type": "integer", "minimum": 0 },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainVariable" }
        },
        "conservations": {
          "type": "array",
          "items": { "$ref": "#/$defs/domainConservation" }
        }
      }
    },
    "domainTypeParameter": {
      "type": "object",
      "required": ["kind", "name", "display"],
      "properties": {
        "kind": { "type": "string" },
        "name": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "domainVariable": {
      "type": "object",
      "required": [
        "role",
        "name",
        "quantity_kind",
        "display_unit",
        "canonical_unit",
        "dimension",
        "line"
      ],
      "properties": {
        "role": { "enum": ["across", "through"] },
        "name": { "type": "string" },
        "quantity_kind": { "type": "string" },
        "display_unit": { "type": "string" },
        "canonical_unit": { "type": "string" },
        "dimension": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "domainConservation": {
      "type": "object",
      "required": ["text", "status", "line"],
      "properties": {
        "text": { "type": "string" },
        "status": { "const": "recorded" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentSummary": {
      "type": "object",
      "required": [
        "name",
        "line",
        "port_count",
        "local_expression_count",
        "ports",
        "local_expressions"
      ],
      "properties": {
        "name": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "port_count": { "type": "integer", "minimum": 0 },
        "local_expression_count": { "type": "integer", "minimum": 0 },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentPort" }
        },
        "local_expressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentLocalExpression" }
        }
      }
    },
    "componentPort": {
      "type": "object",
      "required": ["name", "domain", "domain_name", "type_arguments", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "domain_name": { "type": "string" },
        "type_arguments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "enum": [
            "domain_resolved",
            "unknown_domain",
            "generic_arity_mismatch",
            "unvalidated"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "componentLocalExpression": {
      "type": "object",
      "required": ["name", "expression", "status", "line"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "connectionSummary": {
      "type": "object",
      "required": ["left", "right", "domain", "status", "line"],
      "properties": {
        "left": { "type": "string" },
        "right": { "type": "string" },
        "domain": { "type": "string" },
        "status": {
          "enum": [
            "domain_compatible",
            "domain_mismatch",
            "medium_mismatch",
            "frame_mismatch",
            "axis_mismatch",
            "domain_parameter_mismatch",
            "unresolved_endpoint"
          ]
        },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "assemblySummary": {
      "type": "object",
      "required": [
        "name",
        "status",
        "line",
        "component_count",
        "port_count",
        "connection_count",
        "component_equation_count",
        "local_expression_count",
        "operator_call_count",
        "predictor_call_count",
        "domain_count",
        "domain_plans",
        "solver_preview",
        "connection_sets",
        "equations",
        "variables",
        "boundary",
        "residual_graph"
      ],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "component_count": { "type": "integer", "minimum": 0 },
        "port_count": { "type": "integer", "minimum": 0 },
        "connection_count": { "type": "integer", "minimum": 0 },
        "component_equation_count": { "type": "integer", "minimum": 0 },
        "local_expression_count": { "type": "integer", "minimum": 0 },
        "operator_call_count": { "type": "integer", "minimum": 0 },
        "predictor_call_count": { "type": "integer", "minimum": 0 },
        "domain_count": { "type": "integer", "minimum": 0 },
        "domain_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyDomainPlan" }
        },
        "solver_preview": { "$ref": "#/$defs/assemblySolverPreview" },
        "connection_sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyConnectionSet" }
        },
        "equations": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyEquation" }
        },
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyVariable" }
        },
        "boundary": { "$ref": "#/$defs/assemblyBoundary" },
        "residual_graph": { "$ref": "#/$defs/assemblyResidualGraph" }
      }
    },
    "assemblyDomainPlan": {
      "type": "object",
