{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/review.schema.json",
  "title": "EngLang Review Artifact",
  "type": "object",
  "required": [
    "format",
    "review_schema_version",
    "compiler_version",
    "source_path",
    "source_hash",
    "syntax_summary",
    "variable_table",
    "warning_list",
    "plot_manifest",
    "schema_summary",
    "system_summary"
  ],
  "properties": {
    "format": { "const": "eng-review-preview-1" },
    "review_schema_version": { "const": 1 },
    "compiler_version": { "type": "string" },
    "source_path": { "type": "string" },
    "source_hash": { "type": "string" },
    "syntax_summary": {
      "type": "object",
      "required": ["scripts", "schemas", "systems", "equations", "fast_bindings"]
    },
    "variable_table": { "type": "array" },
    "warning_list": { "type": "array" },
    "plot_manifest": { "type": "object" },
    "schema_summary": { "type": "array" },
    "system_summary": { "type": "array" }
  }
}
