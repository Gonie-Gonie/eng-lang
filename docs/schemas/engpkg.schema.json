{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eng-lang.local/schemas/engpkg.schema.json",
  "title": "EngLang Standalone Package Metadata",
  "type": "object",
  "required": [
    "format",
    "package_format_version",
    "runtime_abi",
    "profile",
    "runner",
    "engine",
    "source_root",
    "artifact_root",
    "source",
    "bytecode",
    "source_hash",
    "bytecode_hash",
    "entry_name",
    "entry",
    "args_schema",
    "args_field_count",
    "args_help",
    "dependency_count",
    "dependencies",
    "dependency_hashes"
  ],
  "properties": {
    "format": { "const": "engpkg-stable-1" },
    "package_format_version": { "const": "1" },
    "runtime_abi": { "const": "eng-runtime-cli-v1" },
    "profile": { "const": "repro" },
    "runner": { "const": "run.bat" },
    "engine": { "const": "eng.exe" },
    "source_root": { "const": "source" },
    "artifact_root": { "const": "build/result" },
    "source": { "type": "string" },
    "bytecode": { "type": "string" },
    "source_hash": { "type": "string" },
    "bytecode_hash": { "type": "string" },
    "entry_name": { "type": "string" },
    "entry": { "type": "string" },
    "args_schema": { "type": "string" },
    "args_field_count": { "type": "string" },
    "args_help": { "const": "ARGS_HELP.txt" },
    "dependency_count": { "type": "string" },
    "dependencies": { "type": "string" },
    "dependency_hashes": { "type": "string" }
  }
}
