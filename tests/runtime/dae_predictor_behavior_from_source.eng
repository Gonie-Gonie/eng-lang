domain DaeBehaviorScalar {
    across x: DimensionlessNumber [1]
    across z: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component PredictorDaeNode {
    port node: DaeBehaviorScalar
    predicted = predictor(node.x)
    der(node.x) + predicted - 1 eq 0
    node.z - predicted eq 0
}

system DaePredictorBehaviorSource {
    node = PredictorDaeNode()
    connect node.node to node.node
}

dae_predictor_result = solve component_graph
with {
    solver = implicit_euler_dae
    timestep = 1 s
    duration = 2 s
    initial = 0
    initial_derivative = 1
    initial_algebraic = [0, 0]
    tolerance = 0.000000001
    max_iter = 40
}

report {
    show dae_predictor_result
}
