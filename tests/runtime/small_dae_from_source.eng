domain DaeTemperature package "eng.std.domains.scalar" version "0.1.0" {
    across T: AbsoluteTemperature [K]
    across T_ref: AbsoluteTemperature [K]
    through balance: TemperatureDelta [K]
    conservation sum(balance) = 0
}

component ThermalDaeNode {
    port node: DaeTemperature
    der(node.T) + (node.T - node.T_ref) / 1 s eq 0 K/s
    node.T_ref eq 300 K
}

system SmallDaeSource {
    node = ThermalDaeNode()
    connect node.node to node.node
}

dae_result = solve component_graph
with {
    solver = implicit_euler_dae
    timestep = 1 s
    duration = 2 s
    initial = 310
    initial_derivative = -10
    initial_algebraic = 300
    tolerance = 0.000000001
    max_iter = 30
}

report {
    show dae_result
}
