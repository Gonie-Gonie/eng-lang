args {
    drive_csv: CsvFile = file("data/dynamic_component_drive.csv")
}

schema DriveData {
    time: DateTime index
    drive: DimensionlessNumber [1]
}

drive_data = promote csv args.drive_csv as DriveData

domain ScalarInputSignal {
    across x: DimensionlessNumber [1]
    across y: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component AdaptiveDrivenNonlinearAlgebraicNode {
    port node: ScalarInputSignal
    input drive: DimensionlessNumber [1] = 0
    der(node.x) + sin(node.x) - drive eq 0
    node.y * node.y eq cos(node.x) + drive
}

system DynamicAdaptiveNonlinearAlgebraicTimeSeries {
    node = AdaptiveDrivenNonlinearAlgebraicNode()
    connect node.node to node.node
}

adaptive_ts_result = solve component_graph
with {
    solver = dynamic_component_adaptive_heun
    timestep = 1 s
    duration = 4 s
    initial = 0.5
    initial_algebraic = 1
    inputs = drive_data.drive
    tolerance = 0.0001
    max_iter = 10000
}

report {
    show adaptive_ts_result
}
