domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component ParameterizedFunctionDecayNode {
    port node: ScalarState
    parameter k: DimensionlessNumber [1] = 0.25
    der(node.x) + k * sin(node.x) eq 0
}

system DynamicParameterizedFunctionExplicit {
    node = ParameterizedFunctionDecayNode(k=0.5)
    connect node.node to node.node
}

parameterized_function_explicit_result = solve component_graph
with {
    solver = dynamic_component_explicit_euler
    timestep = 0.25 s
    duration = 1 s
    initial = 0.5
}

report {
    show parameterized_function_explicit_result
}
