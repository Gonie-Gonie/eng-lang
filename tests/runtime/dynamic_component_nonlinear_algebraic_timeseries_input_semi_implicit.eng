args {
    drive_csv: CsvFile = file("data/dynamic_component_drive.csv")
}

schema DriveData {
    time: DateTime index
    drive: DimensionlessNumber [1]
}

drive_data = promote csv args.drive_csv as DriveData

domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component DynamicNode {
    port node: ScalarState
    der(node.x) + node.balance eq 0
}

component DrivenNonlinearBoundary {
    port node: ScalarState
    input drive: DimensionlessNumber [1] = 0
    node.balance * node.balance eq node.x + drive
}

system DynamicNonlinearAlgebraicTimeSeriesSemiImplicit {
    node = DynamicNode()
    boundary = DrivenNonlinearBoundary()
    connect node.node to boundary.node
}

nonlinear_ts_result = solve component_graph
with {
    solver = dynamic_component_semi_implicit_euler
    timestep = 1 s
    duration = 4 s
    initial = 0.5
    initial_algebraic = [-1, 0.5, 1]
    inputs = drive_data.drive
    tolerance = 0.000001
    max_iter = 20
}

report {
    show nonlinear_ts_result
}
