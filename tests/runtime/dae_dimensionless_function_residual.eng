domain DaeFunctionPair package "eng.std.domains.scalar" version "0.1.0" {
    across x: DimensionlessNumber [1]
    across z: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component FunctionDaeNode {
    port node: DaeFunctionPair
    der(node.x) + sin(node.x) eq 0
    node.z - cos(node.x) eq 0
}

system DaeDimensionlessFunctionResidual {
    node = FunctionDaeNode()
    connect node.node to node.node
}

dae_function_result = solve component_graph
with {
    solver = implicit_euler_dae
    timestep = 0.25 s
    duration = 0.5 s
    initial = 0.5
    initial_derivative = -0.4794255386
    initial_algebraic = [0.877582562, 0]
    tolerance = 0.000000001
    max_iter = 40
}

report {
    show dae_function_result
}
