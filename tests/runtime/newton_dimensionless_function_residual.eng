domain DimensionlessScalar package "eng.std.domains.scalar" version "0.1.0" {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component FunctionResidualNode {
    port node: DimensionlessScalar
    sqrt(node.x) eq 2
}

system NewtonDimensionlessFunctionResidual {
    node = FunctionResidualNode()
    connect node.node to node.node
}

function_result = solve component_graph
with {
    solver = newton
    initial = [1, 0]
    tolerance = 0.000000001
    max_iter = 30
}

report {
    show function_result
}
