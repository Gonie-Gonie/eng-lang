domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component FunctionDecayNode {
    port node: ScalarState
    der(node.x) + sin(node.x) eq 0
}

system DynamicFunctionExplicit {
    node = FunctionDecayNode()
    connect node.node to node.node
}

function_explicit_result = solve component_graph
with {
    solver = dynamic_component_explicit_euler
    timestep = 0.25 s
    duration = 1 s
    initial = 0.5
}

report {
    show function_explicit_result
}
