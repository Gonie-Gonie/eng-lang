system SourceParameterOverride {
    parameter gain: DimensionlessNumber [1] = 1
    state x: DimensionlessNumber = 0
    output shifted: DimensionlessNumber [1]

    equation {
        der(x) eq gain / 1 s
        shifted eq x + gain
    }
}

sim = simulate SourceParameterOverride
with {
    gain = 2
    timestep = 1 s
    duration = 2 s
    solver = rk4
}

report {
    plot sim.x and sim.shifted over Time
    with {
        unit y = 1
        title = "Source parameter override solve"
    }
}
