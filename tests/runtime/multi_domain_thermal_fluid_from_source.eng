domain Thermal {
    across T: AbsoluteTemperature [degC]
    through Q: HeatRate [kW]
    conservation sum(Q) = 0
}

domain Fluid[Medium M] {
    across p: Pressure [Pa]
    through m_dot: MassFlowRate [kg/s]
    conservation sum(m_dot) = 0
}

component ZoneBoundary {
    port heat: Thermal
    boundary_T = heat.T = 22 degC
    boundary_Q = heat.Q = 1 kW
}

component AmbientBoundary {
    port heat: Thermal
}

component PumpBoundary {
    port supply: Fluid[Water]
    supply_pressure = supply.p = p_supply
    supply_flow = supply.m_dot = m_dot_supply
}

component PipeRun {
    port inlet: Fluid[Water]
    port outlet: Fluid[Water]
    outlet.p + dp eq inlet.p
    outlet.m_dot + inlet.m_dot eq 0
}

component ReturnBoundary {
    port inlet: Fluid[Water]
}

system ThermalFluidLoop {
    zone = ZoneBoundary()
    ambient = AmbientBoundary()
    pump = PumpBoundary(p_supply=220000 Pa, m_dot_supply=0.2 kg/s)
    pipe = PipeRun(dp=20000 Pa)
    return_node = ReturnBoundary()

    connect zone.heat to ambient.heat
    connect pump.supply to pipe.inlet
    connect pipe.outlet to return_node.inlet
}

runtime_marker = 1

report {
    show runtime_marker
}
