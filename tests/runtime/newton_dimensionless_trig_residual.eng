domain DimensionlessTrig package "eng.std.domains.scalar" version "0.1.0" {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component TrigResidualNode {
    port node: DimensionlessTrig
    tan(node.x) eq 1
}

system NewtonDimensionlessTrigResidual {
    node = TrigResidualNode()
    connect node.node to node.node
}

trig_result = solve component_graph
with {
    solver = newton
    initial = [0.7, 0]
    tolerance = 0.000000001
    max_iter = 30
}

report {
    show trig_result
}
