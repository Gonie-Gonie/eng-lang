domain ScalarSignal {
    across x: DimensionlessNumber [1]
    across y: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component AdaptiveNonlinearAlgebraicNode {
    port node: ScalarSignal
    der(node.x) + sin(node.x) eq 0
    node.y * node.y eq cos(node.x)
}

system DynamicAdaptiveNonlinearAlgebraicFailure {
    node = AdaptiveNonlinearAlgebraicNode()
    connect node.node to node.node
}

adaptive_failure = solve component_graph
with {
    solver = dynamic_component_adaptive_heun
    timestep = 0.25 s
    duration = 1 s
    initial = 0.5
    initial_algebraic = 0.5
    tolerance = 0.000000000001
    max_iter = 1
}

report {
    show adaptive_failure
}
