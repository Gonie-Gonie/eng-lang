domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component DecayNode {
    port node: ScalarState
    der(node.x) eq -0.5 * node.x
}

system DynamicAffineResidualScaleUnsupported {
    node = DecayNode()
    connect node.node to node.node
}

scaled_affine_result = solve component_graph
with {
    solver = dynamic_component_explicit_euler
    timestep = 1 s
    duration = 3 s
    initial = 4
    residual_scale = node.equation_1 = 2
}

report {
    show scaled_affine_result
}
