domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component AdaptiveImplicitDerivativeNode {
    port node: ScalarState
    der(node.x) * der(node.x) + der(node.x) eq 2
}

system DynamicAdaptiveImplicitDerivativeNonconvergence {
    node = AdaptiveImplicitDerivativeNode()
    connect node.node to node.node
}

adaptive_result = solve component_graph
with {
    solver = dynamic_component_adaptive_heun
    timestep = 0.25 s
    duration = 1 s
    initial = 0.5
    tolerance = 0.000000000001
    max_iter = 1
}

report {
    show adaptive_result
}
