domain NonlinearPower package "eng.std.domains.scalar" version "0.1.0" {
    across q: HeatRate [kW]
    through balance: HeatRate [kW]
    conservation sum(balance) = 0
}

component CoupledHeatNode {
    port source: NonlinearPower
    port target: NonlinearPower
    source.q * source.q / 1 kW + target.q eq 6 kW
    target.q * target.q / 1 kW + source.q eq 6 kW
}

system NonlinearInitialVectorMismatch {
    node = CoupledHeatNode()
    connect node.source to node.source
    connect node.target to node.target
}

nonlinear_result = solve component_graph
with {
    solver = newton
    initial = [1 kW, 3 kW]
    tolerance = 0.000000001
    max_iter = 60
}

report {
    show nonlinear_result
}
