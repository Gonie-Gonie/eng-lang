domain ScalarState {
    across x: DimensionlessNumber [1]
    through balance: DimensionlessNumber [1]
    conservation sum(balance) = 0
}

component ImplicitDerivativeNode {
    port node: ScalarState
    der(node.x) * der(node.x) + der(node.x) eq 2
}

system DynamicImplicitDerivativeNonconvergence {
    node = ImplicitDerivativeNode()
    connect node.node to node.node
}

explicit_result = solve component_graph
with {
    solver = dynamic_component_explicit_euler
    timestep = 0.25 s
    duration = 1 s
    initial = 0.5
    tolerance = 0.000000000001
    max_iter = 1
}

report {
    show explicit_result
}
