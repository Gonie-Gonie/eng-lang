input_file = render template file("model/base.txt")
with {
    values = { case_id = "case_001" }
    output = file("outputs/input.txt")
    overwrite = true
}

process_result = run command "cmd"
with {
    args = ["/C", "echo", "ok"]
    expected_outputs = [file("outputs/result.csv")]
    tool_version = "demo 1.0"
    retry = 1
    allow_failure = false
}

db = open sqlite file("outputs/results.sqlite")
write process_result to db.table("runs")
with {
    mode = append
}
