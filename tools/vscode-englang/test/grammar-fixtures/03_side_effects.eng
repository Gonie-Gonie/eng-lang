input_file = render template file("model/base.txt")
rendered_template = render template args.template_source to args.rendered_output
with {
    values = { case_id = "case_001" }
    output = file("outputs/input.txt")
    overwrite = true
}

process_result = run command "cmd"
with {
    args = ["/C", "echo", "ok"]
    expected_outputs = [file("outputs/result.csv")]
    tool_version = "demo 1.0"
    retry = 1
    allow_failure = false
}

db = open sqlite file("outputs/results.sqlite")
write process_result to db.table("runs")
persisted_runs = read sqlite db.table("runs") as ProcessResult
with {
    mode = append
    mode = insert
    mode = upsert
    mode = replace
    transaction = commit
    transaction = rollback
}

args {
    output: DirectoryPath = dir("outputs")
}

export summary to csv join(args.output, "summary.csv") {
    Q_total as kWh with ".2"
    eta as 1 with ".3"
    args.energy_total as kWh with ".2"
    report.peak_Q as kW with ".2"
}
with {
    overwrite = true
}

write text join(args.output, "summary.txt"), "done"
write json "outputs/energy.json", E_coil
print "Q total = {Q_total: .2 kWh}"
log info "summary exported"
download args.file_url to args.raw_file
write args.process_rows to args.database.table("runs")
write result.rows to storage.database.table("runs")
args_persisted_runs = read sqlite args.database.table("runs") as ProcessResult
property_persisted_runs = read sqlite storage.database.table("runs") as ProcessResult
args_records_payload = promote json records args.records_payload as ProcessResult
property_records_payload = promote json records api.payload as ProcessResult
