system RoomThermal {
    state T: AbsoluteTemperature = 20 degC
    parameter C: HeatCapacity = 1200 kJ/K
    input Q_internal: HeatRate = 500 W
    output Q_load: HeatRate = Q_internal
    equation energy_balance:
        C * der(T) eq Q_internal
}

domain Thermal package "eng.std.domains.thermal" version "0.1.0" {
    across T: AbsoluteTemperature [degC]
    through Q: HeatRate [kW]
    conservation sum(Q) = 0
}

component RoomBoundary {
    port heat: Thermal
}

component Coil {
    port heat: Thermal
    parameter UA: Conductance [W/K] = 500 W/K
    delayed_T = delay(heat.T, 1 s)
    predicted_T = predictor(heat.T)
    predicted_alias_T = predict(heat.T)
}

component AmbientBoundary {
    port heat: Thermal
}

system ComponentFixture {
    room = RoomBoundary()
    coil = Coil()
    connect room.heat to coil.heat
}

states RoomState {
    T_air: AbsoluteTemperature [degC]
}

inputs RoomInput {
    T_out: AbsoluteTemperature [degC]
}

outputs RoomOutput {
    T_zone: AbsoluteTemperature [degC]
}

system StateSpaceFixture {
    state x: StateVector[RoomState] = [22 degC]
    input u: InputVector[RoomInput] = [8 degC]
    output y: OutputVector[RoomOutput]
    operator A: LinearOperator[RoomState -> Derivative[RoomState]] = [[-0.012 1/min]]
}
