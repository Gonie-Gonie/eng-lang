/// Core workflow fixture
# normal comment
use eng.path
import eng.table

schema SensorData {
    time: DateTime [iso8601]
    T_supply: AbsoluteTemperature [degC]
    m_dot: MassFlowRate [kg/s]
}

args {
    input: CsvFile = file("data/sensor.csv")
    output: DirectoryPath = dir("outputs")
}

sensor = promote csv args.input as SensorData
sensor_from_path = promote csv "data/sensor.csv" as SensorData
sensor_from_file = promote csv file("data/sensor.csv") as SensorData
raw = read json file("data/config.json")
message = "Q = {sensor.T_supply: .2 degC}"

write text file("outputs/summary.txt"), message
report {
    show sensor
}
