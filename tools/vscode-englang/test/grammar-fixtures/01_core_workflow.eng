/// Core workflow fixture
# normal comment
// slash comment
use eng.path
use eng.stats
use eng.system
import eng.table

schema SensorData {
    time: DateTime [iso8601]
    T_supply: AbsoluteTemperature [degC]
    m_dot: MassFlowRate [kg/s]
}

args {
    input: CsvFile = file("data/sensor.csv")
    output: DirectoryPath = dir("outputs")
}

sensor = promote csv args.input as SensorData
sensor_from_path = promote csv "data/sensor.csv" as SensorData
sensor_from_file = promote csv file("data/sensor.csv") as SensorData
raw = read json file("data/config.json")
notes_text = read text args.notes
toml_text = read toml args.config_toml
api_payload = read json api_response.body
message = "Q = {sensor.T_supply: .2 degC}"
escaped_message = "Path \"outputs\\summary.txt\"\nRows = {weather_rows}"
message_with_expr = "Mean = {mean(sensor.T_supply + 1 K, axis=Time): .2 degC}"
message_with_binding = "Rows = {weather_rows}"
custom_value = calibrate(args.input, sensor.T_supply, message, 1 kW + 2 kW, axis=Time)
custom_training = custom_train(sensor.T_supply, algorithm="linear", hidden=[8], epochs=20, split=args.split_ref)
existing_output = exists(args.output)
input_parent = parent(args.input)
input_stem = stem(args.input)
input_ext = extension(args.input)

write text file("outputs/summary.txt"), message
write standard_text sensor
with {
    output = join(args.output, "sensor_standard.txt")
}
report {
    show sensor
}
