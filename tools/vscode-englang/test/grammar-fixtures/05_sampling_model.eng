designs = sample lhs
alias_designs = sample uniform
latin_designs = sample latin_hypercube
latin_hyphen_designs = sample latin-hypercube
with {
    count = 12
    seed = 7
    people_density = uniform(0.03 person/m2, 0.12 person/m2)
    cooling_cop = uniform(2.5, 5.0)
}

model = train regression designs
with {
    target = annual_electricity
    features = [people_density, cooling_cop]
    test = 0.25
    seed = 7
}
legacy_model = regression_table(designs, target=annual_electricity, features=[people_density, cooling_cop], test=0.25, seed=7)
split = train_test_split(designs, target=annual_electricity, features=[people_density, cooling_cop], test=0.25, seed=7)
trained = train_regression(designs, target=annual_electricity, features=[people_density], algorithm="linear", seed=7)
compact_model = regression(split)
neural_model = mlp(split, hidden=[8], epochs=20)
ann_model = ann(split, hidden=[8], epochs=20)
metrics = evaluate(model)
split_metrics = evaluate(model, split=split)
card = model_card(model)
leakage = leakage_lint(split)
predictions = predict model using designs
surrogate_predictions = predict surrogate_model using designs
filtered_designs = filter designs
where {
    cooling_cop > 3.0
}
selected_designs = select designs columns people_density, cooling_cop
selected_single = select designs column people_density
sorted_designs = sort designs by cooling_cop desc
sorted_asc_designs = sort designs by people_density asc
joined_designs = join designs with predictions
derived = derive designs column annual_electricity = cooling_cop * 100 kWh
derived_columns = derive designs columns annual_cooling = cooling_cop * 50 kWh
first_design = require_one designs
with {
    on_none = error "No design row"
    on_many = error "Multiple design rows"
}

cases = materialize cases designs
with {
    output_root = "outputs"
    case_id = case_id
    resume = true
}

case_results = apply run_case over designs
with {
    step = run_case
}

template_case_inputs = apply case_input_template over cases
case_inputs = apply(case_input_template, over=cases)
with {
    template = file("model/native_case_template.txt")
    missing = error
    artifact_kind = "case_input"
}

collected = collect results case_results
arg_cases = materialize cases args.designs
property_cases = materialize cases study.designs
arg_case_results = apply args.case_step over args.designs
property_case_results = apply workflow.case_step over study.designs
arg_predictions = predict args.model_ref using args.designs
property_predictions = predict surrogate.model using study.designs
arg_model = train regression from args.training_results
property_model = train regression on study.training_results
collected_args = collect results args.case_results
collected_property = collect results cases.results
arg_filtered_designs = filter args.designs
property_filtered_designs = filter study.designs
arg_selected_designs = select args.designs columns people_density, cooling_cop
property_selected_designs = select study.designs column people_density
arg_sorted_designs = sort args.designs by cooling_cop desc
property_sorted_designs = sort study.designs by people_density asc
arg_joined_designs = join args.designs with args.predictions
property_joined_designs = join study.designs with model.predictions
arg_derived_designs = derive args.designs column annual_electricity = cooling_cop * 100 kWh
property_derived_designs = derive study.designs column annual_cooling = cooling_cop * 50 kWh
arg_first_design = require_one args.designs
property_first_design = require_one study.designs
arg_case_inputs_call = apply(args.case_step, over=args.cases)
property_case_inputs_call = apply(workflow.case_step, over=study.cases)
