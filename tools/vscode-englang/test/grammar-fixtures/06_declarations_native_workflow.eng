script LegacyScript
struct LegacyArgs

draft_declaration_keywords = [schema, class, system, domain, component, fn, method, test, const, state, input, parameter, output, port, across, through, operator, index]

const cp_water: SpecificHeat [J/kg/K] = 4.18 kJ/K

class Zone {
    name: String
    area: Area [m2]
    method label() -> String = self.name
}

fn coil_heat(m_dot: MassFlowRate, dT: TemperatureDelta) -> HeatRate {
    Q = m_dot * cp_water * dT
    return Q
}

fn pass_predictions(predictions: Table[T]) -> Table[T] {
    return predictions
}

Q_from_call = coil_heat(0.2 kg/s, 8 K)

test "coil heat stays positive" {
    assert cp_water > 0 J/kg/K
    assert cp_water == 4.18 kJ/K within 0.01 kJ/K
    golden "summary.csv" matches file("golden/summary.csv")
}

api_url: Url = url("https://example.org/weather")
api_key: Secret[String] = secret env("WEATHER_API_KEY")

schema WorkflowArtifactRefs {
    db: DbConnection
    table: DbTableRef
    model_card: ModelCard
    model_artifact: ModelArtifact
    predictions: Table[T]
    maybe_output: Optional[DirectoryPath]
    heat_series: TimeSeries[Time]
    process: ProcessResult
}

response = http get api_url
args_response = http get args.api_url
with {
    query = {
        station = "demo"
        serviceKey = api_key
    }
    offline_response = file("data/weather-response.json")
    cache = true
    cache_key = ["weather", "example"]
    expected_sha256 = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
    body_size_limit = 2 MB
    response_body_limit = 2 MB
}

response_text = response.body
response_hash = response.response_hash
payload = read json file("data/weather.json")
api_contract = promote json payload as WeatherApiPayload
json_config = promote json file("data/workflow.json") as WorkflowConfig
toml_config = promote toml file("data/case.toml") as CaseConfig
weather = promote json records payload.records as WeatherApiRecord

submitted = http post api_url
with {
    body = response_text
    status_code = 201
}

updated = http put api_url
patched = http patch api_url
probed = http head api_url
raw_request = http request api_url
fetched = http fetch api_url

download url("https://example.org/file.csv") to file("outputs/file.csv")
with {
    cache = true
    cache_dir = dir("build/cache")
}

copy file("data/template.txt") to file("outputs/template.txt")
mkdir dir("outputs/archive")
move file("outputs/template.txt") to file("outputs/archive/template.txt")
delete dir("outputs/archive")
