script LegacyScript
struct LegacyArgs

catalog_import_keywords = [use, import, from, as]
catalog_deprecated_keywords = [script, struct]
catalog_declaration_keywords = [schema, class, system, domain, component]
catalog_function_keywords = [fn, method]
catalog_test_keywords = [test]
catalog_block_keywords = [args, where, with, on]
catalog_modifier_keywords = [const, state, input, parameter, output, port, across, through, operator, index]
catalog_report_keywords = [report, show, plot, line, bar, histogram, summarize, summary, distribution]
catalog_validation_keywords = [validate, assert, golden, matches, within, constraints, missing, interpolate, monotonic, fill, align, resample, check, coverage]
catalog_side_effect_keywords = [write, export, copy, move, delete, mkdir, render, template, print, log]
catalog_external_boundary_keywords = [run, command, open, sqlite, http, get, post, put, patch, head, request, fetch, download]
catalog_solver_keywords = [simulate, solve, connect, conservation, equation, operator, states, inputs, outputs]
catalog_workflow_keywords = [promote, read, text, standard_text, json, toml, csv, records, column, columns, to, policy, package, version, model, return, if, else, sample, filter, select, derive, sort, require_one, materialize, cases, collect, results, apply, train, regression, predict]
catalog_operator_words = [eq, is, and, or, not, between, over, by, using, in, into, of, vs, to, within, matches]
catalog_constants = [true, false, none, null, info, warn, debug, error, safe, normal, repro, append, insert, upsert, replace, commit, rollback, keep, empty, interpolate, monotonic, linear, interval, ensemble, monte_carlo, source_linear_terms, finite_difference, asc, desc, pending, planned, partial, running, passed, failed, succeeded, skipped, blocked, completed, rendered, collected, cached, stale, hit, miss, created, updated, metadata_ready, warnings_present, diagnostics_present, fixed_step, rk4, adaptive_heun, fixed_point, newton, implicit_euler_dae, dynamic_component_explicit_euler, dynamic_component_semi_implicit_euler, dynamic_component_adaptive_heun, trapezoidal, lhs, latin_hypercube, latin-hypercube, grid, random, uniform]

const cp_water: SpecificHeat [J/kg/K] = 4.18 kJ/K

class Zone {
    name: String
    area: Area [m2]
    method label() -> String = self.name
}

zone = Zone {
    name = "Lab"
    area = 25 m2
}

larger_zone = zone with {
    area = 30 m2
}

fn coil_heat(m_dot: MassFlowRate [kg/s], dT: TemperatureDelta [K]) -> HeatRate [W] {
    Q = m_dot * cp_water * dT
    return Q
}

fn pass_predictions(predictions: Table[T]) -> Table[T] {
    return predictions
}

Q_from_call = coil_heat(0.2 kg/s, 8 K)

test "coil heat stays positive" {
    assert cp_water > 0 J/kg/K
    assert cp_water == 4.18 kJ/K within 0.01 kJ/K
    golden "summary.csv" matches file("golden/summary.csv")
}

api_url: Url = url("https://example.org/weather")
api_key: Secret[String] = secret env("WEATHER_API_KEY")

schema WorkflowArtifactRefs {
    db: DbConnection
    table: DbTableRef
    model_card: ModelCard
    model_artifact: ModelArtifact
    predictions: Table[T]
    records: Array[WeatherApiRecord]
    tags: List[String]
    flags: Bool[]
    maybe_output: Optional[DirectoryPath]
    heat_series: TimeSeries[Time]
    process: ProcessResult
}

response = http get api_url
args_response = http get args.api_url
with {
    query = {
        station = "demo"
        year = args.year
        selected_station = station.station_id
        serviceKey = api_key
    }
    headers = {
        Accept = "application/json"
        Authorization = secret env("WEATHER_API_KEY")
    }
    offline_response = file("data/weather-response.json")
    cache = true
    cache_key = ["weather", "example"]
    cache_ttl = 30 min
    expected_sha256 = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
    body_size_limit = 2 MB
    response_body_limit = 2 MB
}

response_text = response.body
response_hash = response.response_hash
payload = read json file("data/weather.json")
api_contract = promote json payload as WeatherApiPayload
json_config = promote json file("data/workflow.json") as WorkflowConfig
toml_config = promote toml file("data/case.toml") as CaseConfig
weather = promote json records payload.records as WeatherApiRecord

submitted = http post api_url
with {
    body = response_text
    status_code = 201
}

updated = http put api_url
patched = http patch api_url
probed = http head api_url
raw_request = http request api_url
fetched = http fetch api_url

download url("https://example.org/file.csv") to file("outputs/file.csv")
with {
    cache = true
    cache_dir = dir("build/cache")
    cache_ttl = 1 h
}

copy file("data/template.txt") to file("outputs/template.txt")
mkdir dir("outputs/archive")
move file("outputs/template.txt") to file("outputs/archive/template.txt")
delete dir("outputs/archive")
