args {
    measured: CsvFile = file("data/measured_zone.csv")
}

schema MeasuredZoneData {
    time: DateTime index
    T_zone: TimeSeries[Time] of AbsoluteTemperature [degC]
}

T_supply_meas = measured(12 degC, std=0.2 K)
Q_coil_dist = normal(mean=5 kW, std=0.8 kW, samples=31)
Q_total_unc = propagate(Q_coil_dist, method=linear, scale=1.08, offset=0.4 kW)
Q_probability = probability(Q_total_unc < 10 kW)
I_window = 850 W/m^2
occupant_density = 0.12 people/m2
Q_series: TimeSeries[Time] of HeatRate [kW] = 5 kW
E_series_call = integrate(Q_series, over=Time)
E_series_command = integrate Q_series over Time
mean_Q_series = mean(Q_series, axis=Time)
peak_Q_series = max(Q_series, axis=Time)
mean_Q_command = mean Q_series over Time
with {
    sensor_std = 0.2 kW
}
coverage = check coverage measured.T_zone
aligned_series = align measured.T_zone with simulated.T_zone
resampled_series = resample measured.T_zone to simulated.T_zone

sim = simulate RoomThermal
with {
    timestep = 10 min
    duration = 30 min
    solver = adaptive_heun
    tolerance = 0.001
    initial = [20 degC]
    body_size_limit = 2 MB
}

solve_result = solve component_graph
with {
    initial = [310 K, 305 K]
    initial_derivative = [-10 K/s, -5 K/s]
    initial_algebraic = [300 K, 0 K, 295 K, 0 K]
    inputs = measured.T_zone
    jacobian = source_linear_terms
    mass_matrix = [[1, 0], [0, 1]]
    max_iter = 40
    relaxation = 0.5
    residual_scale = node.equation_1 = 2 kW
    residual_scales = [node.equation_1 = 2 kW, node.equation_2 = 4 kW]
    variable_scales = [2, 4]
    algebraic_initialization = none
    tolerance = 0.000000001
}

validate Q_probability > 0.95

on {
    status == passed
}

report {
    summarize Q_total_unc by [mean, time_weighted_mean, p90, p95]
    show Q_total_unc
    show coverage.status
    plot Q_series over Time
    plot distribution(Q_coil_dist)
    with {
        unit y = kW
        title = "Coil uncertainty"
        confidence_band = sensor_std
    }
}
