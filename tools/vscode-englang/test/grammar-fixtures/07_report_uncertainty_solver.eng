args {
    measured: CsvFile = file("data/measured_zone.csv")
}

schema MeasuredZoneData {
    time: DateTime index
    T_zone: TimeSeries[Time] of AbsoluteTemperature [degC]

    constraints {
        time is monotonic
        T_zone between 0 degC and 60 degC
    }

    missing {
        T_zone: interpolate max_gap=10 min
    }
}

T_supply_meas = measured(12 degC, std=0.2 K)
Q_coil_dist = normal(mean=5 kW, std=0.8 kW, samples=31)
Q_dist_alias = distribution(kind=normal, mean=5 kW, sigma=0.8 kW, n=31)
Q_range_alias = distribution(kind=uniform, lower=1 kW, upper=8 kW, samples=11)
Q_total_unc = propagate(Q_coil_dist, method=linear, scale=1.08, offset=0.4 kW)
Q_total_mc = propagate(Q_coil_dist, method=linear)
with {
    uncertainty = monte_carlo
    samples = 64
    seed = 7
}
Q_total_interval = propagate(Q_coil_dist, method=linear)
with {
    uncertainty = interval
}
Q_total_ensemble = propagate(Q_coil_dist, method=linear)
with {
    uncertainty = ensemble
}
Q_probability = probability(Q_total_unc < 10 kW)
I_window = 850 W/m^2
occupant_density = 0.12 people/m2
Q_series: TimeSeries[Time] of HeatRate [kW] = 5 kW
E_series_call = integrate(Q_series, over=Time)
E_series_command = integrate Q_series over Time
mean_Q_series = mean(Q_series, axis=Time)
low_Q_series = min(Q_series, axis=Time)
peak_Q_series = max(Q_series, axis=Time)
mean_Q_command = mean Q_series over Time
with {
    sensor_std = 0.2 kW
}
coverage = check coverage measured.T_zone
filled_zone = fill missing measured.T_zone
aligned_series = align measured.T_zone with simulated.T_zone
aligned_to_series = align measured.T_zone to simulated.T_zone
resampled_series = resample measured.T_zone to simulated.T_zone
resampled_with_series = resample measured.T_zone with simulated.T_zone
resampled_by_series = resample measured.T_zone by 30 min

sim = simulate RoomThermal
with {
    timestep = 10 min
    duration = 30 min
    solver = adaptive_heun
    tolerance = 0.001
    initial = [20 degC]
    body_size_limit = 2 MB
}

solve_result = solve component_graph
with {
    initial = [310 K, 305 K]
    initial_derivative = [-10 K/s, -5 K/s]
    initial_algebraic = [300 K, 0 K, 295 K, 0 K]
    inputs = measured.T_zone
    jacobian = source_linear_terms
    mass_matrix = [[1, 0], [0, 1]]
    max_iter = 40
    relaxation = 0.5
    residual_scale = node.equation_1 = 2 kW
    residual_scales = [node.equation_1 = 2 kW, node.equation_2 = 4 kW]
    variable_scales = [2, 4]
    algebraic_initialization = none
    tolerance = 0.000000001
}

validate Q_probability > 0.95

status_cases = materialize cases measured
with {
    status = pending
    status = planned
    status = passed
    status = partial
    status = running
    status = failed
    status = succeeded
    status = skipped
    status = blocked
    status = completed
    status = rendered
    status = collected
    status = missing
    status = empty
}

on {
    status == pending
    status == planned
    status == passed
    status == partial
    status == running
    status == failed
    status == succeeded
    status == skipped
    status == blocked
    status == completed
    status != rendered
    status != collected
    status != missing
    status != empty
}

report {
    summarize Q_total_unc by [mean, time_weighted_mean, p90, p95]
    show Q_total_unc
    show coverage.status
    plot Q_series over Time
    plot Q_series and Q_total_unc over Time
    plot histogram(Q_series)
    plot line(Q_series)
    plot bar(Q_series)
    plot parity(Q_series)
    plot residuals(Q_series)
    plot distribution(Q_coil_dist)
    with {
        unit y = kW
        title = "Coil uncertainty"
        confidence_band = sensor_std
    }
}
arg_coverage = check coverage args.measured_zone
arg_filled_zone = fill missing args.measured_zone
arg_aligned_series = align args.measured_zone with args.simulated_zone
arg_resampled_series = resample args.measured_zone to args.simulated_zone
arg_resampled_by_series = resample args.measured_zone by 30 min
arg_E_series_call = integrate(args.Q_series, over=args.Time)
property_E_series_call = integrate(sensor.Q_series, over=axis.Time)
arg_E_series_command = integrate args.Q_series over args.Time
arg_mean_series = mean(args.Q_series, axis=args.Time)
property_mean_series = mean(sensor.Q_series, axis=axis.Time)
arg_mean_command = mean args.Q_series over args.Time
rmse_value = rmse measured_data.T_zone vs sim.T_zone
