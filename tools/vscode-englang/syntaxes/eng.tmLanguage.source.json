{
  "generatedPath": "eng.tmLanguage.json",
  "grammar": {
    "scopeName": "source.englang",
    "name": "EngLang",
    "patterns": [
      { "include": "#comments" },
      { "include": "#strings" },
      { "include": "#modules" },
      { "include": "#withOptions" },
      { "include": "#declarations" },
      { "include": "#members" },
      { "include": "#blocks" },
      { "include": "#workflowPhrases" },
      { "include": "#keywords" },
      { "include": "#operators" },
      { "include": "#builtins" },
      { "include": "#constants" },
      { "include": "#types" },
      { "include": "#units" },
      { "include": "#numbers" },
      { "include": "#punctuation" }
    ],
    "repository": {
      "comments": {
        "patterns": [
          {
            "name": "comment.line.documentation.englang",
            "match": "^\\s*///.*$"
          },
          {
            "name": "comment.line.number-sign.englang",
            "match": "#.*$"
          }
        ]
      },
      "strings": {
        "patterns": [
          {
            "name": "string.quoted.double.englang",
            "begin": "\"",
            "end": "\"",
            "patterns": [
              {
                "name": "constant.character.escape.englang",
                "match": "\\\\."
              },
              {
                "name": "support.namespace.module.englang",
                "match": "\\beng(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
              },
              {
                "name": "meta.interpolation.englang",
                "begin": "\\{",
                "end": "\\}",
                "beginCaptures": {
                  "0": { "name": "punctuation.definition.interpolation.begin.englang" }
                },
                "endCaptures": {
                  "0": { "name": "punctuation.definition.interpolation.end.englang" }
                },
                "patterns": [
                  {
                    "name": "variable.other.interpolation.englang",
                    "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*\\b"
                  },
                  {
                    "name": "punctuation.separator.format.englang",
                    "match": ":"
                  },
                  {
                    "name": "constant.numeric.format.englang",
                    "match": "\\.[0-9]+"
                  },
                  {
                    "name": "constant.other.unit.format.englang",
                    "match": "(?<![A-Za-z0-9_])(J/kg/K|people/m2|person/m2|W/m\\^2|W/m2|kg/s|W/K|J/K|kJ/K|degC|kWh|kPa|kW|kJ|MJ|MB|KB|Wh|Pa|kg|cm|mm|m2|m3|min|K|m|s|h|W|J|B|%)(?![A-Za-z0-9_/])"
                  }
                ]
              }
            ]
          }
        ]
      },
      "modules": {
        "patterns": [
          {
            "name": "support.namespace.module.englang",
            "match": "\\beng(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
          }
        ]
      },
      "declarations": {
        "patterns": [
          {
            "name": "entity.name.type.declaration.englang",
            "match": "\\b(schema|system|domain|component|class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
              "1": { "name": "storage.type.declaration.englang" },
              "2": { "name": "entity.name.type.englang" }
            }
          },
          {
            "name": "meta.declaration.function.englang",
            "match": "\\b(fn|method)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
              "1": { "name": "storage.type.function.englang" },
              "2": { "name": "entity.name.function.englang" }
            }
          },
          {
            "name": "meta.declaration.constant.englang",
            "match": "\\b(const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
              "1": { "name": "storage.modifier.englang" },
              "2": { "name": "variable.other.constant.englang" }
            }
          },
          {
            "name": "meta.declaration.test.englang",
            "match": "\\b(test)\\s+(\"[^\"]*\")",
            "captures": {
              "1": { "name": "storage.type.test.englang" },
              "2": { "name": "entity.name.section.englang" }
            }
          },
          {
            "name": "meta.declaration.system-member.englang",
            "match": "\\b(state|input|parameter|output)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
              "1": { "name": "storage.modifier.englang" },
              "2": { "name": "variable.other.property.englang" }
            }
          },
          {
            "name": "meta.declaration.interface-member.englang",
            "match": "\\b(port|across|through)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
              "1": { "name": "storage.type.declaration.englang" },
              "2": { "name": "variable.other.property.englang" }
            }
          },
          {
            "name": "storage.modifier.schema.englang",
            "match": "\\b(index)\\b"
          },
          {
            "name": "meta.declaration.field.englang",
            "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
            "captures": {
              "2": { "name": "variable.other.property.englang" }
            }
          },
          {
            "name": "meta.declaration.binding.englang",
            "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*=)",
            "captures": {
              "2": { "name": "variable.other.definition.englang" }
            }
          }
        ]
      },
      "blocks": {
        "patterns": [
          {
            "name": "storage.type.block.englang",
            "match": "\\b(args|report|constraints|missing|test|with|on)\\b(?=\\s*\\{)"
          }
        ]
      },
      "workflowPhrases": {
        "patterns": [
          {
            "name": "meta.workflow.export-summary-csv.englang",
            "match": "\\b(export)\\s+(summary)\\s+(to)\\s+(csv)\\b",
            "captures": {
              "1": { "name": "keyword.control.side-effect.englang" },
              "2": { "name": "keyword.control.report.englang" },
              "3": { "name": "keyword.operator.word.englang" },
              "4": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.write-text.englang",
            "match": "\\b(write)\\s+(text)\\b",
            "captures": {
              "1": { "name": "keyword.control.side-effect.englang" },
              "2": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.read-structured.englang",
            "match": "\\b(read)\\s+(json|toml|text|csv)\\b",
            "captures": {
              "1": { "name": "keyword.control.workflow.englang" },
              "2": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.open-sqlite.englang",
            "match": "\\b(open)\\s+(sqlite)\\b",
            "captures": {
              "1": { "name": "keyword.control.external-boundary.englang" },
              "2": { "name": "keyword.control.external-boundary.englang" }
            }
          },
          {
            "name": "meta.workflow.db-write.englang",
            "match": "\\b(write)\\s+([A-Za-z_][A-Za-z0-9_.]*)\\s+(to)\\s+([A-Za-z_][A-Za-z0-9_]*)\\.(table)\\b",
            "captures": {
              "1": { "name": "keyword.control.side-effect.englang" },
              "2": { "name": "variable.other.local.englang" },
              "3": { "name": "keyword.operator.word.englang" },
              "4": { "name": "variable.other.local.englang" },
              "5": { "name": "support.function.builtin.englang" }
            }
          },
          {
            "name": "meta.workflow.sample-method.englang",
            "match": "\\b(sample)\\s+(lhs|latin_hypercube|latin-hypercube|grid|random|uniform)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "support.function.builtin.englang" }
            }
          },
          {
            "name": "meta.workflow.materialize-cases.englang",
            "match": "\\b(materialize)\\s+(cases)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.collect-results.englang",
            "match": "\\b(collect)\\s+(results)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.predict-model.englang",
            "match": "\\b(predict)\\s+([A-Za-z_][A-Za-z0-9_.]*)\\s+(using)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "variable.other.local.englang" },
              "3": { "name": "keyword.operator.word.englang" }
            }
          },
          {
            "name": "meta.workflow.apply-step.englang",
            "match": "\\b(apply)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(over)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "entity.name.function.workflow-step.englang" },
              "3": { "name": "keyword.operator.word.englang" }
            }
          },
          {
            "name": "meta.workflow.check-coverage.englang",
            "match": "\\b(check)\\s+(coverage)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "support.function.builtin.englang" }
            }
          },
          {
            "name": "meta.workflow.promote-json-records.englang",
            "match": "\\b(promote)\\s+(json)\\s+(records)\\b",
            "captures": {
              "1": { "name": "support.function.builtin.englang" },
              "2": { "name": "keyword.control.workflow.englang" },
              "3": { "name": "keyword.control.workflow.englang" }
            }
          },
          {
            "name": "meta.workflow.http-request.englang",
            "match": "\\b(http)\\s+(get|post|put|patch|head|request|fetch)\\b",
            "captures": {
              "1": { "name": "keyword.control.external-boundary.englang" },
              "2": { "name": "keyword.control.external-boundary.englang" }
            }
          },
          {
            "name": "meta.report.unit-axis.englang",
            "match": "\\b(unit)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
            "captures": {
              "1": { "name": "variable.parameter.property.englang" },
              "2": { "name": "variable.other.property.englang" },
              "3": { "name": "keyword.operator.englang" }
            }
          }
        ]
      },
      "members": {
        "patterns": [
          {
            "name": "variable.other.property.englang",
            "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
          }
        ]
      },
      "keywords": {
        "patterns": [
          {
            "name": "keyword.control.import.englang",
            "match": "\\b(use|import|from|as)\\b"
          },
          {
            "name": "keyword.control.deprecated.englang",
            "match": "\\b(script|struct)\\b"
          },
          {
            "name": "keyword.control.report.englang",
            "match": "\\b(report|show|plot|line|bar|histogram|summarize|summary|distribution)\\b"
          },
          {
            "name": "keyword.control.validation.englang",
            "match": "\\b(validate|assert|golden|matches|within)\\b"
          },
          {
            "name": "keyword.control.side-effect.englang",
            "match": "\\b(write|export|copy|move|delete|render|template|print|log)\\b"
          },
          {
            "name": "keyword.control.external-boundary.englang",
            "match": "\\b(run|command|open|sqlite|http|get|post|put|patch|head|request|fetch|download)\\b"
          },
          {
            "name": "keyword.control.solver.englang",
            "match": "\\b(simulate|solve|connect|conservation|equation)\\b"
          },
          {
            "name": "keyword.control.workflow.englang",
            "match": "\\b(const|promote|read|text|json|toml|csv|records|to|policy|package|version|port|across|through|input|parameter|state|output|model|return|if|else)\\b"
          }
        ]
      },
      "operators": {
        "patterns": [
          {
            "name": "keyword.operator.word.englang",
            "match": "\\b(eq|is|none|null|and|or|not|between|over|by|using|in|where|into|of|vs)\\b"
          },
          {
            "name": "keyword.operator.englang",
            "match": "(->|==|!=|>=|<=|=|\\+|-|\\*|/|>|<)"
          }
        ]
      },
      "builtins": {
        "patterns": [
          {
            "name": "support.function.builtin.englang",
            "match": "\\b(file|dir|join|parent|stem|extension|exists|url|secret|env|date|datetime|select_first_row|filter|select|derive|sort|require_one|check|coverage|fill_missing|align|resample|sample|uniform|normal|grid|random|lhs|latin_hypercube|materialize|apply|collect|run_case|measured|interval|ensemble|propagate|probability|train_test_split|regression|regression_table|train_regression|mlp|evaluate|model_card|leakage_lint|predict|mean|time_weighted_mean|min|max|median|std|p90|p95|rmse|duration_above|integrate|der|delay|sum)\\b"
          }
        ]
      },
      "withOptions": {
        "patterns": [
          {
            "name": "variable.parameter.property.englang",
            "match": "\\b(args|query|headers|body|fixture|status_code|status_class|response_hash|hash|url|expected_sha256|body_size_limit|response_body_limit|expected_outputs|artifact_kind|tool_version|values|output|output_root|case_id|step|env|cwd|timeout|retry|allow_failure|cache|cache_dir|cache_key|overwrite|mode|key|recursive|resume|confirm|expected_step|year|count|seed|test|features|target|algorithm|hidden|epochs|missing|max_gap|method|status|start|end|return_column|mean|std|error|samples|scale|offset|uncertainty|sensor_std|timestep|duration|solver|tolerance|atol|rtol|unit|title|confidence_band|on_none|on_many|split|database|table|schema|path|format|profile|runner|scheduler|transaction)\\b(?=\\s*=)"
          }
        ]
      },
      "constants": {
        "patterns": [
          {
            "name": "constant.language.englang",
            "match": "\\b(true|false|none|null|info|warn|debug|error|safe|normal|repro|append|insert|upsert|keep|empty|interpolate|monotonic|linear|pending|running|passed|failed|succeeded|skipped|blocked|completed|cached|stale|hit|miss|created|updated|metadata_ready|warnings_present|diagnostics_present|fixed_step|rk4|adaptive_heun|fixed_point|newton|implicit_euler_dae|dynamic_component_explicit_euler|dynamic_component_semi_implicit_euler|dynamic_component_adaptive_heun|trapezoidal)\\b"
          },
          {
            "name": "constant.language.format.englang",
            "match": "(?<=\\[)(iso8601|unix|epoch|utc)(?=\\])"
          }
        ]
      },
      "types": {
        "patterns": [
          {
            "name": "support.type.englang",
            "match": "\\b(Report|ReviewDocument|RunPlan|RunLog|RunLock|OutputManifest|CacheManifest|ProcessResult|HttpResponse|CoverageResult|QualityResult|Table|TableRow|SampleTable|CaseTable|CaseManifest|TimeSeries|Time|Prediction|PredictionManifest|ModelCard|ModelArtifact|DbConnection|DbTableRef|DbWriteManifest|NetworkCache|ArtifactManifest|Path|FilePath|DirectoryPath|CsvFile|TextFile|JsonFile|TomlFile|Url|Secret|Optional|Bool|Int|Float|Number|String|Date|DateTime|Duration|DimensionlessNumber|AbsoluteTemperature|TemperatureDelta|Length|Area|Volume|Conductance|HeatCapacity|SpecificHeat|HeatRate|ElectricPower|MechanicalPower|Energy|Mass|MassFlowRate|Pressure|Irradiance|PeopleDensity|Ratio|ReynoldsNumber)\\b"
          }
        ]
      },
      "units": {
        "patterns": [
          {
            "name": "meta.quantity.literal.englang",
            "match": "\\b[0-9]+(?:\\.[0-9]+)?\\s+(J/kg/K|people/m2|person/m2|W/m\\^2|W/m2|kg/s|W/K|J/K|kJ/K|degC|kWh|kPa|kW|kJ|MJ|MB|KB|Wh|Pa|kg|cm|mm|m2|m3|min|K|m|s|h|W|J|B|%)(?![A-Za-z0-9_/])",
            "captures": {
              "1": { "name": "constant.other.unit.englang" }
            }
          },
          {
            "name": "constant.other.unit.englang",
            "match": "(?<=\\[)(J/kg/K|people/m2|person/m2|W/m\\^2|W/m2|kg/s|W/K|J/K|kJ/K|degC|kWh|kPa|kW|kJ|MJ|MB|KB|Wh|Pa|kg|cm|mm|m2|m3|min|K|m|s|h|W|J|B|%)(?=\\])"
          },
          {
            "name": "constant.other.unit.englang",
            "match": "(?<![A-Za-z0-9_])(J/kg/K|people/m2|person/m2|W/m\\^2|W/m2|kg/s|W/K|J/K|kJ/K|degC|kWh|kPa|kW|kJ|MJ|MB|KB|Wh|Pa|kg|cm|mm|m2|m3|min|K|m|s|h|W|J|B|%)(?![A-Za-z0-9_/])"
          }
        ]
      },
      "numbers": {
        "patterns": [
          {
            "name": "constant.numeric.englang",
            "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
          }
        ]
      },
      "punctuation": {
        "patterns": [
          {
            "name": "punctuation.section.block.begin.englang",
            "match": "\\{"
          },
          {
            "name": "punctuation.section.block.end.englang",
            "match": "\\}"
          },
          {
            "name": "punctuation.section.brackets.begin.englang",
            "match": "\\["
          },
          {
            "name": "punctuation.section.brackets.end.englang",
            "match": "\\]"
          },
          {
            "name": "punctuation.section.parens.begin.englang",
            "match": "\\("
          },
          {
            "name": "punctuation.section.parens.end.englang",
            "match": "\\)"
          },
          {
            "name": "punctuation.separator.comma.englang",
            "match": ","
          },
          {
            "name": "punctuation.separator.colon.englang",
            "match": ":"
          },
          {
            "name": "punctuation.accessor.dot.englang",
            "match": "\\."
          }
        ]
      }
    }
  }
}
