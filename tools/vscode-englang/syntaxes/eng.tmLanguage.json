{
  "scopeName": "source.englang",
  "name": "EngLang",
  "patterns": [
    {
      "name": "comment.line.number-sign.englang",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.double.englang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.englang",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.control.englang",
      "match": "\\b(schema|script|struct|system|domain|across|through|conservation|component|port|connect|equation|input|parameter|state|promote|from|policy|missing|where|plot|line|bar|histogram|return|der|integrate|mean|max|median|std|duration_above)\\b"
    },
    {
      "name": "support.type.englang",
      "match": "\\b(Report|Table|TimeSeries|DateTime|String|Number|Duration|AbsoluteTemperature|TemperatureDelta|Length|Conductance|HeatCapacity|SpecificHeat|HeatRate|ElectricPower|MechanicalPower|Energy|MassFlowRate|Ratio|ReynoldsNumber)\\b"
    },
    {
      "name": "constant.numeric.englang",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    {
      "name": "keyword.operator.englang",
      "match": "(->|==|=|\\beq\\b|\\+|-|\\*|/|>|<|>=|<=)"
    }
  ]
}
