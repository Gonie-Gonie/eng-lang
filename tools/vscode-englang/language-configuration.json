{
  "comments": {
    "lineComment": "#"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*///.*$",
      "action": {
        "indent": "none",
        "appendText": "/// "
      }
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{\\s*(?:(#|//).*)?$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "wordPattern": "(latin-hypercube)|(-?\\d+(?:\\.\\d+)?)|([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ]
}
