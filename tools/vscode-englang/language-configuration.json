{
  "comments": {
    "lineComment": "#"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*///.*$",
      "action": {
        "indent": "none",
        "appendText": "/// "
      }
    }
  ],
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ]
}
