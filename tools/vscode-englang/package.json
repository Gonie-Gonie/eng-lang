{
  "name": "englang",
  "displayName": "EngLang",
  "description": "EngLang editor tooling with diagnostics, hover, completion, and run commands.",
  "version": "0.1.0",
  "publisher": "englang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:englang"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "englang",
        "aliases": [
          "EngLang",
          "eng"
        ],
        "extensions": [
          ".eng"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "englang",
        "scopeName": "source.englang",
        "path": "./syntaxes/eng.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "englang",
        "path": "./snippets/eng.json"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "unit",
        "description": "Unit symbols and unit-typed values."
      },
      {
        "id": "quantity",
        "description": "Quantity values and quantity-typed symbols."
      },
      {
        "id": "axis",
        "description": "Time axes and aligned axis metadata."
      },
      {
        "id": "timeseries",
        "description": "Time series values and related accessors."
      },
      {
        "id": "uncertain",
        "description": "Measured, interval, ensemble, or propagated uncertainty symbols."
      },
      {
        "id": "sideEffect",
        "description": "Workflow operations that declare or perform side effects."
      },
      {
        "id": "external",
        "description": "External boundaries such as files, commands, HTTP, and DB access."
      },
      {
        "id": "validation",
        "description": "Validation, assertion, golden, and coverage symbols."
      },
      {
        "id": "report",
        "description": "Report, plot, summary, and rendered artifact symbols."
      },
      {
        "id": "solver",
        "description": "Solver, equation, conservation, and simulation symbols."
      },
      {
        "id": "planned",
        "description": "Planned workflow nodes or artifacts."
      },
      {
        "id": "internal",
        "description": "Internal runtime, package, or implementation symbols."
      },
      {
        "id": "riskHigh",
        "description": "High-risk symbols reported by compiler review metadata."
      },
      {
        "id": "riskMedium",
        "description": "Medium-risk symbols reported by compiler review metadata."
      },
      {
        "id": "state",
        "description": "State declarations and state-like workflow data."
      },
      {
        "id": "input",
        "description": "Input declarations, parameters, and input-like workflow data."
      },
      {
        "id": "model",
        "description": "Model training, prediction, evaluation, and model artifact symbols."
      },
      {
        "id": "db",
        "description": "SQLite connections, table writes, and DB boundary symbols."
      },
      {
        "id": "cache",
        "description": "Cache declarations, cache keys, and cache-backed workflow records."
      },
      {
        "id": "workflowStep",
        "description": "Case orchestration and workflow step symbols."
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "englang",
        "scopes": {
          "type.unit": [
            "constant.other.unit.englang",
            "support.type.englang"
          ],
          "property.unit": [
            "constant.other.unit.englang",
            "variable.other.property.englang"
          ],
          "variable.quantity": [
            "variable.other.definition.englang",
            "support.type.englang"
          ],
          "property.quantity": [
            "variable.other.property.englang",
            "support.type.englang"
          ],
          "parameter.quantity": [
            "variable.parameter.property.englang",
            "support.type.englang"
          ],
          "variable.axis": [
            "entity.name.function.workflow-step.englang",
            "variable.other.definition.englang"
          ],
          "property.axis": [
            "entity.name.function.workflow-step.englang",
            "variable.other.property.englang"
          ],
          "variable.timeseries": [
            "entity.name.function.englang",
            "variable.other.definition.englang"
          ],
          "property.timeseries": [
            "entity.name.function.englang",
            "variable.other.property.englang"
          ],
          "function.defaultLibrary": [
            "support.function.builtin.englang"
          ],
          "namespace.defaultLibrary": [
            "support.namespace.module.englang"
          ],
          "namespace.internal": [
            "support.namespace.module.englang",
            "comment.line.number-sign.englang"
          ],
          "variable.uncertain": [
            "constant.language.englang",
            "variable.other.definition.englang"
          ],
          "function.uncertain": [
            "support.function.builtin.englang",
            "constant.language.englang"
          ],
          "property.uncertain": [
            "constant.language.englang",
            "variable.other.property.englang"
          ],
          "function.sideEffect": [
            "keyword.control.side-effect.englang"
          ],
          "keyword.sideEffect": [
            "keyword.control.side-effect.englang"
          ],
          "method.sideEffect": [
            "keyword.control.side-effect.englang"
          ],
          "variable.sideEffect": [
            "keyword.control.side-effect.englang",
            "variable.other.definition.englang"
          ],
          "function.external": [
            "keyword.control.external-boundary.englang"
          ],
          "keyword.external": [
            "keyword.control.external-boundary.englang"
          ],
          "method.external": [
            "keyword.control.external-boundary.englang"
          ],
          "variable.external": [
            "keyword.control.external-boundary.englang",
            "variable.other.definition.englang"
          ],
          "keyword.validation": [
            "keyword.control.validation.englang"
          ],
          "variable.validation": [
            "keyword.control.validation.englang",
            "variable.other.definition.englang"
          ],
          "property.validation": [
            "keyword.control.validation.englang",
            "variable.other.property.englang"
          ],
          "function.validation": [
            "support.function.builtin.englang",
            "keyword.control.validation.englang"
          ],
          "keyword.report": [
            "keyword.control.report.englang"
          ],
          "variable.report": [
            "keyword.control.report.englang",
            "variable.other.definition.englang"
          ],
          "property.report": [
            "keyword.control.report.englang",
            "variable.other.property.englang"
          ],
          "function.solver": [
            "keyword.control.solver.englang",
            "support.function.builtin.englang"
          ],
          "keyword.solver": [
            "keyword.control.solver.englang"
          ],
          "variable.solver": [
            "keyword.control.solver.englang",
            "variable.other.definition.englang"
          ],
          "keyword.deprecated": [
            "keyword.control.deprecated.englang"
          ],
          "variable.state": [
            "storage.modifier.englang",
            "variable.other.definition.englang"
          ],
          "property.state": [
            "storage.modifier.englang",
            "variable.other.property.englang"
          ],
          "variable.input": [
            "storage.modifier.englang",
            "variable.other.definition.englang"
          ],
          "parameter.input": [
            "variable.parameter.property.englang",
            "storage.modifier.englang"
          ],
          "variable.model": [
            "entity.name.function.englang",
            "variable.other.definition.englang"
          ],
          "function.model": [
            "support.function.builtin.englang",
            "entity.name.function.englang"
          ],
          "property.model": [
            "entity.name.function.englang",
            "variable.other.property.englang"
          ],
          "variable.db": [
            "keyword.control.external-boundary.englang",
            "variable.other.definition.englang"
          ],
          "keyword.db": [
            "keyword.control.external-boundary.englang"
          ],
          "variable.cache": [
            "keyword.control.workflow.englang",
            "variable.other.definition.englang"
          ],
          "property.cache": [
            "keyword.control.workflow.englang",
            "variable.other.property.englang"
          ],
          "keyword.workflowStep": [
            "entity.name.function.workflow-step.englang"
          ],
          "function.workflowStep": [
            "entity.name.function.workflow-step.englang",
            "support.function.builtin.englang"
          ],
          "property.workflowStep": [
            "entity.name.function.workflow-step.englang",
            "variable.other.property.englang"
          ],
          "variable.riskHigh": [
            "invalid.deprecated.englang",
            "variable.other.definition.englang"
          ],
          "variable.riskMedium": [
            "markup.warning.englang",
            "variable.other.definition.englang"
          ],
          "variable.planned": [
            "comment.line.number-sign.englang",
            "variable.other.definition.englang"
          ],
          "variable.internal": [
            "comment.line.number-sign.englang",
            "variable.other.definition.englang"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[englang]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "EngLang",
      "properties": {
        "englang.runtimePath": {
          "type": "string",
          "default": "",
          "description": "Path to eng.exe. Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the EngLang editor service executable. Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.diagnosticsBackend": {
          "type": "string",
          "default": "eng-cli",
          "enum": [
            "eng-cli",
            "lsp-snapshot"
          ],
          "enumDescriptions": [
            "File diagnostics from eng.exe. Best for stable open, save, and manual checks.",
            "Live editor diagnostics aligned with hover, completion, and unsaved-buffer checks."
          ],
          "description": "Choose how the Problems panel is updated. Use eng-cli for stable file checks, or lsp-snapshot for live editor diagnostics while typing."
        },
        "englang.executionProfile": {
          "type": "string",
          "default": "normal",
          "enum": [
            "normal",
            "safe",
            "repro"
          ],
          "enumDescriptions": [
            "Run declared effects and write the standard review artifacts.",
            "Reject workflows with explicit write, export, process, file, or DB mutation effects.",
            "Require reproducibility metadata for sampling, network, and cache boundaries."
          ],
          "description": "Execution profile used by EngLang run commands. normal runs declared effects; safe rejects side effects; repro requires reproducibility metadata for sampling, network, and cache boundaries."
        },
        "englang.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run EngLang diagnostics when .eng files are opened or saved."
        },
        "englang.lintOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Update EngLang diagnostics for unsaved .eng buffers after a short typing pause."
        },
        "englang.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Use compiler-backed semantic tokens for role-aware highlighting of variables, units, quantities, side effects, reports, validations, solver terms, and workflow boundaries."
        },
        "englang.reviewRiskDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show subtle editor line markers and overview-ruler marks for high and medium EngLang review risks."
        }
      }
    },
    "commands": [
      {
        "command": "englang.checkFile",
        "title": "EngLang: Check Current File"
      },
      {
        "command": "englang.runFile",
        "title": "EngLang: Run Current File"
      },
      {
        "command": "englang.runExample",
        "title": "EngLang: Run Example..."
      },
      {
        "command": "englang.switchProfile",
        "title": "EngLang: Switch Execution Profile..."
      },
      {
        "command": "englang.reviewFile",
        "title": "EngLang: Open Current File Review JSON"
      },
      {
        "command": "englang.openReviewPanel",
        "title": "EngLang: Open Current File Review Panel"
      },
      {
        "command": "englang.openReport",
        "title": "EngLang: Open Last Report"
      },
      {
        "command": "englang.openLastArtifact",
        "title": "EngLang: Open Last Run Artifact..."
      },
      {
        "command": "englang.openReviewJson",
        "title": "EngLang: Open Last Run Review JSON"
      },
      {
        "command": "englang.openOutputManifest",
        "title": "EngLang: Open Last Run Output Manifest"
      },
      {
        "command": "englang.openRunLog",
        "title": "EngLang: Open Last Run Log"
      },
      {
        "command": "englang.openRunPlan",
        "title": "EngLang: Open Last Run Plan"
      },
      {
        "command": "englang.openProcessResults",
        "title": "EngLang: Open Last Run Process Results"
      },
      {
        "command": "englang.openCacheManifest",
        "title": "EngLang: Open Last Run Cache Manifest"
      },
      {
        "command": "englang.showSemanticTokensDebug",
        "title": "EngLang: Inspect Highlight Tokens"
      }
    ]
  }
}
