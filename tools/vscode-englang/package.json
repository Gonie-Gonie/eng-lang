{
  "name": "englang",
  "displayName": "EngLang",
  "description": "EngLang editor tooling with diagnostics, hover, completion, and program execution.",
  "version": "0.1.0",
  "publisher": "englang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:englang",
    "workspaceContains:**/*.eng"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "englang",
        "aliases": [
          "EngLang",
          "eng"
        ],
        "extensions": [
          ".eng"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "englang",
        "scopeName": "source.englang",
        "path": "./syntaxes/eng.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "englang",
        "path": "./snippets/eng.json"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "unit",
        "description": "Unit symbols and unit-typed values."
      },
      {
        "id": "quantity",
        "description": "Quantity values and quantity-typed symbols."
      },
      {
        "id": "axis",
        "description": "Time axes and aligned axis metadata."
      },
      {
        "id": "timeseries",
        "description": "Time series values and related accessors."
      },
      {
        "id": "uncertain",
        "description": "Measured, interval, ensemble, or propagated uncertainty symbols."
      },
      {
        "id": "sideEffect",
        "description": "Workflow operations that declare or perform side effects."
      },
      {
        "id": "external",
        "description": "External boundaries such as files, commands, HTTP, and DB access."
      },
      {
        "id": "validation",
        "description": "Validation, assertion, golden, and coverage symbols."
      },
      {
        "id": "report",
        "description": "Report, plot, summary, and rendered artifact symbols."
      },
      {
        "id": "solver",
        "description": "Solver, equation, conservation, and simulation symbols."
      },
      {
        "id": "planned",
        "description": "Planned workflow nodes or artifacts."
      },
      {
        "id": "internal",
        "description": "Internal runtime, package, or implementation symbols."
      },
      {
        "id": "riskHigh",
        "description": "High-risk symbols reported by compiler review metadata."
      },
      {
        "id": "riskMedium",
        "description": "Medium-risk symbols reported by compiler review metadata."
      },
      {
        "id": "state",
        "description": "State declarations and state-like workflow data."
      },
      {
        "id": "input",
        "description": "Input declarations, parameters, and input-like workflow data."
      },
      {
        "id": "output",
        "description": "Output declarations and output-like workflow data."
      },
      {
        "id": "model",
        "description": "Model training, prediction, evaluation, and model artifact symbols."
      },
      {
        "id": "db",
        "description": "SQLite connections, table writes, and DB boundary symbols."
      },
      {
        "id": "cache",
        "description": "Cache declarations, cache keys, and cache-backed workflow records."
      },
      {
        "id": "workflowStep",
        "description": "Case orchestration and workflow step symbols."
      }
    ],
