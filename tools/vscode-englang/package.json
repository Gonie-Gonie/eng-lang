    "configurationDefaults": {
      "[englang]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "EngLang",
      "properties": {
        "englang.runtimePath": {
          "type": "string",
          "default": "",
          "description": "Path to the EngLang check/run tool (eng.exe). Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the EngLang live editor tool (eng-lsp.exe). Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.problemsSource": {
          "type": "string",
          "default": "file",
          "enum": [
            "file",
            "live"
          ],
          "enumDescriptions": [
            "Run quieter file checks when a file opens, saves, or is checked manually.",
            "Update Problems while typing from the current unsaved buffer."
          ],
          "description": "Choose how the Problems panel is updated. File checks are quieter; live checks update while typing from the current unsaved buffer."
        },
        "englang.executionProfile": {
          "type": "string",
          "default": "normal",
          "enum": [
            "normal",
            "safe",
            "repro"
          ],
          "enumDescriptions": [
            "Run declared effects and write the standard review artifacts.",
            "Reject workflows with explicit write, export, process, file, or DB mutation effects.",
            "Require reproducibility metadata for sampling, network, and cache boundaries."
          ],
          "description": "Execution profile used by EngLang program runs. normal runs declared effects; safe rejects side effects; repro requires reproducibility metadata for sampling, network, and cache boundaries."
        },
        "englang.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run EngLang diagnostics when .eng files are opened or saved."
        },
        "englang.lintOnChange": {
          "type": "boolean",
          "default": true,
          "description": "When Problems source is live, update EngLang diagnostics for unsaved .eng buffers after a short typing pause."
        },
        "englang.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Use compiler-backed role-aware colors for variables, units, quantities, side effects, reports, validations, solver terms, and workflow boundaries."
        },
        "englang.reviewRiskDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show subtle editor line markers and overview-ruler marks for high and medium EngLang review risks."
        }
      }
    },
