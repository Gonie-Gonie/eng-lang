    "configurationDefaults": {
      "[englang]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.glyphMargin": true
      }
    },
    "configuration": {
      "title": "EngLang",
      "properties": {
        "englang.runtimePath": {
          "type": "string",
          "default": "",
          "description": "Path to the EngLang check/run tool (eng.exe). Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the EngLang live editor tool (eng-lsp.exe). Leave empty to use the bundled executable, workspace executable, or PATH."
        },
        "englang.diagnosticsMode": {
          "type": "string",
          "default": "file",
          "enum": [
            "file",
            "live"
          ],
          "enumDescriptions": [
            "Use saved-file Problems diagnostics when a file opens, saves, or is checked manually.",
            "Use current-buffer Problems diagnostics while typing from the unsaved editor."
          ],
          "description": "Choose how VS Code Problems diagnostics are produced for EngLang files. File mode is quieter; live mode checks the current unsaved buffer while typing."
        },
        "englang.executionProfile": {
          "type": "string",
          "default": "normal",
          "enum": [
            "normal",
            "safe",
            "repro"
          ],
          "enumDescriptions": [
            "Run declared effects and write the standard review artifacts.",
            "Reject workflows with explicit write, export, process, file, or DB mutation effects.",
            "Require reproducibility metadata for sampling, network, and cache boundaries."
          ],
          "description": "Execution profile used by EngLang program runs. normal runs declared effects; safe rejects side effects; repro requires reproducibility metadata for sampling, network, and cache boundaries."
        },
        "englang.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Enable saved-file EngLang Problems diagnostics when .eng files are opened or saved."
        },
        "englang.lintOnChange": {
          "type": "boolean",
          "default": true,
          "description": "When diagnostics mode is live, update VS Code Problems diagnostics for unsaved .eng buffers after a short typing pause."
        },
        "englang.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Use checked-code role-aware colors for variables, units, quantities, side effects, reports, validations, solver terms, and workflow boundaries."
        },
        "englang.reviewRiskDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show subtle editor line and overview-ruler markers for high and medium review risks, plus a gutter warning icon for high-risk side effects."
        },
        "englang.validationDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show compact pass/fail results beside EngLang object declarations whose class validation rules were evaluated."
        },
        "englang.timeAlignmentDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show compact warnings beside align/resample commands whose latest matching native run produced partial or unavailable TimeSeries output."
        },
        "englang.fallbackDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show compact fill/imputation and runtime fallback warnings from the latest source-matched native run."
        }
      }
