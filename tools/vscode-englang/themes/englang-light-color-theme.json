    "property.quantity": "#006D9A",
    "parameter.quantity": "#0A8795",
    "parameter.timeseries": "#22863A",
    "parameter.sideEffect": "#B31D28",
    "parameter.external": "#C24E00",
    "parameter.db": "#006D75",
    "parameter.validation": "#9A6700",
    "parameter.report": "#6F42C1",
    "parameter.solver": "#00796B",
    "parameter.workflowStep": "#2948C7",
    "variable.axis": "#00796B",
