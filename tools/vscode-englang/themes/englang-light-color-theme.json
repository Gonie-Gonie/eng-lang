    "property.sideEffect": "#C2410C",
    "keyword.external": "#C24E00",
    "function.external": "#B45309",
    "method.external": "#D97706",
    "variable.external": "#A16207",
    "property.external": "#CA6702",
    "keyword.solver": "#00796B",
    "function.solver": "#00897B",
    "variable.solver": "#00695C",
    "property.solver": "#009688",
    "keyword.model": "#6F42C1",
