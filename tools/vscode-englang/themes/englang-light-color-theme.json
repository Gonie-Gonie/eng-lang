{
  "$schema": "vscode://schemas/color-theme",
  "name": "EngLang Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#FBFCFE",
    "editor.foreground": "#1F2933",
    "editorLineNumber.foreground": "#8A96A3",
    "editorCursor.foreground": "#9A6700",
    "editor.selectionBackground": "#CFE8FF",
    "editor.inactiveSelectionBackground": "#E5F1FA",
    "editorGutter.background": "#FBFCFE",
    "sideBar.background": "#F3F6FA",
    "activityBar.background": "#243447",
    "statusBar.background": "#27506A"
  },
  "tokenColors": [
    {
      "scope": ["comment.line.number-sign.englang", "comment.line.double-slash.englang", "comment.line.documentation.englang"],
      "settings": { "foreground": "#6A737D", "fontStyle": "italic" }
    },
    {
      "scope": ["string.quoted.double.englang"],
      "settings": { "foreground": "#22863A" }
    },
    {
      "scope": ["constant.character.escape.englang"],
      "settings": { "foreground": "#9A6700", "fontStyle": "bold" }
    },
    {
      "scope": ["constant.numeric.englang", "constant.numeric.format.englang"],
      "settings": { "foreground": "#B35C00" }
    },
    {
      "scope": ["constant.other.unit.englang", "constant.other.unit.format.englang"],
      "settings": { "foreground": "#9A6700" }
    },
    {
      "scope": ["constant.language.englang", "constant.language.format.englang"],
      "settings": { "foreground": "#6F42C1" }
    },
    {
      "scope": ["support.namespace.module.englang"],
      "settings": { "foreground": "#007C91" }
    },
    {
      "scope": ["support.type.englang", "meta.type.generic.englang", "meta.type.array-suffix.englang", "entity.name.type.englang", "entity.name.type.declaration.englang"],
      "settings": { "foreground": "#007C91" }
    },
    {
      "scope": ["entity.name.function.englang"],
      "settings": { "foreground": "#005CC5" }
    },
    {
      "scope": ["entity.name.function.call.englang"],
      "settings": { "foreground": "#6F42C1" }
    },
    {
      "scope": ["support.function.builtin.englang"],
      "settings": { "foreground": "#7E57C2" }
    },
    {
      "scope": ["support.function.validation.englang"],
      "settings": { "foreground": "#B35C00" }
    },
    {
      "scope": ["support.function.deprecated.englang"],
      "settings": { "foreground": "#D73A49", "fontStyle": "strikethrough" }
    },
    {
      "scope": ["support.function.model.englang"],
      "settings": { "foreground": "#7B3FCF" }
    },
    {
      "scope": ["support.function.uncertain.englang"],
      "settings": { "foreground": "#9C1FA8" }
    },
    {
      "scope": ["support.function.timeseries.englang"],
      "settings": { "foreground": "#3A8F3F" }
    },
    {
      "scope": ["support.function.external-boundary.englang"],
      "settings": { "foreground": "#B45309" }
    },
    {
      "scope": ["support.function.workflow-step.englang"],
      "settings": { "foreground": "#3B5BDB" }
    },
    {
      "scope": ["support.function.solver.englang"],
      "settings": { "foreground": "#00897B" }
    },
    {
      "scope": ["support.function.path.englang"],
      "settings": { "foreground": "#007C91" }
    },
    {
      "scope": ["entity.name.function.solver.englang"],
      "settings": { "foreground": "#00796B" }
    },
    {
      "scope": ["entity.name.section.englang"],
      "settings": { "foreground": "#6F42C1" }
    },
    {
      "scope": ["keyword.control.workflow.englang", "keyword.operator.word.englang", "entity.name.function.workflow-step.englang"],
      "settings": { "foreground": "#2948C7" }
    },
    {
      "scope": ["keyword.control.import.englang"],
      "settings": { "foreground": "#2948C7" }
    },
    {
      "scope": ["keyword.control.validation.englang"],
      "settings": { "foreground": "#9A6700" }
    },
    {
      "scope": ["keyword.control.model.englang"],
      "settings": { "foreground": "#6F42C1" }
    },
    {
      "scope": ["keyword.control.report.englang"],
      "settings": { "foreground": "#6F42C1" }
    },
    {
      "scope": ["keyword.control.side-effect.englang"],
      "settings": { "foreground": "#B31D28" }
    },
    {
      "scope": ["keyword.control.external-boundary.englang"],
      "settings": { "foreground": "#C24E00" }
    },
    {
      "scope": ["keyword.control.solver.englang"],
      "settings": { "foreground": "#00796B" }
    },
    {
      "scope": ["keyword.control.deprecated.englang"],
      "settings": { "foreground": "#D73A49", "fontStyle": "strikethrough" }
    },
    {
      "scope": ["keyword.operator.englang"],
      "settings": { "foreground": "#C24E00" }
    },
    {
      "scope": ["punctuation.definition.interpolation.begin.englang", "punctuation.definition.interpolation.end.englang", "punctuation.separator.format.englang"],
      "settings": { "foreground": "#2948C7", "fontStyle": "bold" }
    },
    {
      "scope": ["punctuation.accessor.dot.englang", "punctuation.definition.string.begin.englang", "punctuation.definition.string.end.englang", "punctuation.section.block.begin.englang", "punctuation.section.block.end.englang", "punctuation.section.brackets.begin.englang", "punctuation.section.brackets.end.englang", "punctuation.section.parens.begin.englang", "punctuation.section.parens.end.englang", "punctuation.separator.colon.englang", "punctuation.separator.comma.englang", "punctuation.separator.parameter.englang"],
      "settings": { "foreground": "#6A737D" }
    },
    {
      "scope": ["storage.type.declaration.englang", "storage.type.function.englang", "storage.type.block.englang", "storage.type.test.englang", "storage.modifier.englang", "storage.modifier.schema.englang"],
      "settings": { "foreground": "#2E7D32" }
    },
    {
      "scope": ["storage.modifier.state.englang"],
      "settings": { "foreground": "#2E7D32" }
    },
    {
      "scope": ["storage.modifier.input.englang"],
      "settings": { "foreground": "#005CC5" }
    },
    {
      "scope": ["storage.modifier.output.englang", "storage.modifier.parameter.englang"],
      "settings": { "foreground": "#9A6700" }
    },
    {
      "scope": ["storage.modifier.operator.englang", "storage.type.interface-member.englang"],
      "settings": { "foreground": "#00796B" }
    },
    {
      "scope": ["variable.other.definition.englang", "variable.other.local.englang", "variable.other.property.englang", "variable.parameter.property.englang", "variable.parameter.argument.englang", "variable.parameter.function.englang", "variable.other.parameter.englang", "variable.other.interpolation.englang"],
      "settings": { "foreground": "#1F2933" }
    },
    {
      "scope": ["variable.parameter.type.englang"],
      "settings": { "foreground": "#007C91" }
    },
    {
      "scope": ["variable.other.constant.englang"],
      "settings": { "foreground": "#9A6700" }
    },
    {
      "scope": ["variable.language.self.englang", "variable.other.input.englang", "variable.other.output.englang", "variable.other.state.englang"],
      "settings": { "foreground": "#005CC5" }
    },
    {
      "scope": ["variable.other.model.englang"],
      "settings": { "foreground": "#5E35B1" }
    },
    {
      "scope": ["variable.other.member.englang"],
      "settings": { "foreground": "#007EA7" }
    },
    {
      "scope": ["variable.other.public-member.englang"],
      "settings": { "foreground": "#006D75" }
    },
    {
      "scope": ["variable.parameter.property.member.englang"],
      "settings": { "foreground": "#9A6700" }
    },
    {
      "scope": ["invalid.deprecated.englang"],
      "settings": { "foreground": "#D73A49", "fontStyle": "bold underline" }
    },
    {
      "scope": ["markup.warning.englang"],
      "settings": { "foreground": "#B35C00", "fontStyle": "underline" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#007C91",
    "type": "#007C91",
    "class": "#2E7D32",
    "interface": "#00796B",
    "parameter": "#9A6700",
    "variable": "#1F2933",
    "property": "#007EA7",
    "function": "#005CC5",
    "method": "#6F42C1",
    "keyword": "#2948C7",
    "modifier": "#2E7D32",
    "string": "#22863A",
    "number": "#B35C00",
    "operator": "#C24E00",
    "comment": { "foreground": "#6A737D", "fontStyle": "italic" },
    "comment.documentation": { "foreground": "#6A737D", "fontStyle": "italic" },
    "class.declaration": "#2E7D32",
    "class.defaultLibrary": "#2E7D32",
    "class.deprecated": { "foreground": "#D73A49", "fontStyle": "strikethrough" },
    "class.static": "#2E7D32",
    "function.declaration": "#005CC5",
    "function.definition": "#005CC5",
    "function.static": "#005CC5",
    "interface.declaration": "#00796B",
    "interface.defaultLibrary": "#00796B",
    "interface.static": "#00796B",
    "keyword.declaration": "#2E7D32",
    "keyword.imported": "#007C91",
    "keyword.defaultLibrary": "#2948C7",
    "keyword.deprecated": { "foreground": "#D73A49", "fontStyle": "strikethrough" },
    "keyword.local": "#2948C7",
    "keyword.static": "#2948C7",
    "method.declaration": "#6F42C1",
    "method.static": "#6F42C1",
    "modifier.static": "#2E7D32",
    "namespace.declaration": "#007C91",
    "namespace.static": "#007C91",
    "parameter.declaration": "#9A6700",
    "parameter.static": "#9A6700",
    "property.declaration": "#007EA7",
    "property.static": "#007EA7",
    "type.static": "#007C91",
    "variable.declaration": "#1F2933",
