{
  "$schema": "vscode://schemas/color-theme",
  "name": "EngLang Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#101317",
    "editor.foreground": "#D7E0EA",
    "editorLineNumber.foreground": "#667180",
    "editorCursor.foreground": "#F4D35E",
    "editor.selectionBackground": "#244766",
    "editor.inactiveSelectionBackground": "#203242",
    "editorGutter.background": "#101317",
    "sideBar.background": "#151A20",
    "activityBar.background": "#0C1015",
    "statusBar.background": "#153243"
  },
  "tokenColors": [
    {
      "scope": ["comment.line.number-sign.englang", "comment.line.double-slash.englang", "comment.line.documentation.englang"],
      "settings": { "foreground": "#7B8491", "fontStyle": "italic" }
    },
    {
      "scope": ["string.quoted.double.englang"],
      "settings": { "foreground": "#8DD694" }
    },
    {
      "scope": ["constant.numeric.englang", "constant.numeric.format.englang"],
      "settings": { "foreground": "#F0A45D" }
    },
    {
      "scope": ["constant.other.unit.englang", "constant.other.unit.format.englang"],
      "settings": { "foreground": "#F4D35E" }
    },
    {
      "scope": ["constant.language.englang", "constant.language.format.englang"],
      "settings": { "foreground": "#D6A3FF" }
    },
    {
      "scope": ["support.namespace.module.englang"],
      "settings": { "foreground": "#66D9E8" }
    },
    {
      "scope": ["support.type.englang", "meta.type.generic.englang", "meta.type.array-suffix.englang", "entity.name.type.englang", "entity.name.type.declaration.englang"],
      "settings": { "foreground": "#66D9E8" }
    },
    {
      "scope": ["entity.name.function.englang", "entity.name.function.call.englang", "support.function.builtin.englang"],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "scope": ["entity.name.function.solver.englang"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "scope": ["entity.name.section.englang"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "scope": ["keyword.control.workflow.englang", "keyword.operator.word.englang", "entity.name.function.workflow-step.englang"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "scope": ["keyword.control.import.englang"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "scope": ["keyword.control.validation.englang"],
      "settings": { "foreground": "#F7C56B" }
    },
    {
      "scope": ["keyword.control.report.englang"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "scope": ["keyword.control.side-effect.englang"],
      "settings": { "foreground": "#FF8A8A" }
    },
    {
      "scope": ["keyword.control.external-boundary.englang"],
      "settings": { "foreground": "#FFB86B" }
    },
    {
      "scope": ["keyword.control.solver.englang"],
      "settings": { "foreground": "#80CBC4" }
    },
    {
      "scope": ["keyword.control.deprecated.englang"],
      "settings": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" }
    },
    {
      "scope": ["keyword.operator.englang"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "scope": ["punctuation.definition.interpolation.begin.englang", "punctuation.definition.interpolation.end.englang", "punctuation.separator.format.englang"],
      "settings": { "foreground": "#82AAFF", "fontStyle": "bold" }
    },
    {
      "scope": ["punctuation.accessor.dot.englang", "punctuation.definition.string.begin.englang", "punctuation.definition.string.end.englang", "punctuation.section.block.begin.englang", "punctuation.section.block.end.englang", "punctuation.section.brackets.begin.englang", "punctuation.section.brackets.end.englang", "punctuation.section.parens.begin.englang", "punctuation.section.parens.end.englang", "punctuation.separator.colon.englang", "punctuation.separator.comma.englang"],
      "settings": { "foreground": "#8A96A3" }
    },
    {
      "scope": ["storage.type.declaration.englang", "storage.type.function.englang", "storage.type.block.englang", "storage.type.test.englang", "storage.modifier.englang", "storage.modifier.schema.englang"],
      "settings": { "foreground": "#B9F27C" }
    },
    {
      "scope": ["variable.other.definition.englang", "variable.other.local.englang", "variable.other.property.englang", "variable.parameter.property.englang", "variable.parameter.argument.englang", "variable.parameter.function.englang", "variable.other.parameter.englang", "variable.other.interpolation.englang"],
      "settings": { "foreground": "#D7E0EA" }
    },
    {
      "scope": ["variable.parameter.type.englang"],
      "settings": { "foreground": "#66D9E8" }
    },
    {
      "scope": ["variable.other.constant.englang"],
      "settings": { "foreground": "#F4D35E" }
    },
    {
      "scope": ["variable.language.self.englang", "variable.other.input.englang", "variable.other.output.englang", "variable.other.state.englang"],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "scope": ["variable.other.member.englang"],
      "settings": { "foreground": "#9CDCFE" }
    },
    {
      "scope": ["variable.other.public-member.englang"],
      "settings": { "foreground": "#4DD0E1" }
    },
    {
      "scope": ["variable.parameter.property.member.englang"],
      "settings": { "foreground": "#F4D35E" }
    },
    {
      "scope": ["invalid.deprecated.englang"],
      "settings": { "foreground": "#FF5C7A", "fontStyle": "bold underline" }
    },
    {
      "scope": ["markup.warning.englang"],
      "settings": { "foreground": "#FFB454", "fontStyle": "underline" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#66D9E8",
    "type": "#66D9E8",
    "class": "#B9F27C",
    "interface": "#80CBC4",
    "parameter": "#F4D35E",
    "variable": "#D7E0EA",
    "property": "#9CDCFE",
    "function": "#9CDCFE",
    "method": "#9CDCFE",
    "keyword": "#82AAFF",
    "modifier": "#B9F27C",
    "string": "#8DD694",
    "number": "#F0A45D",
    "operator": "#FFCB6B",
    "comment": { "foreground": "#7B8491", "fontStyle": "italic" },
    "comment.documentation": { "foreground": "#7B8491", "fontStyle": "italic" },
    "class.declaration": "#B9F27C",
    "class.defaultLibrary": "#B9F27C",
    "class.deprecated": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" },
    "class.static": "#B9F27C",
    "function.declaration": "#9CDCFE",
    "function.definition": "#9CDCFE",
    "function.static": "#9CDCFE",
    "interface.declaration": "#80CBC4",
    "interface.defaultLibrary": "#80CBC4",
    "interface.static": "#80CBC4",
    "keyword.declaration": "#B9F27C",
    "keyword.defaultLibrary": "#82AAFF",
    "keyword.deprecated": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" },
    "keyword.local": "#82AAFF",
    "keyword.static": "#82AAFF",
    "method.declaration": "#9CDCFE",
    "method.static": "#9CDCFE",
    "modifier.static": "#B9F27C",
    "namespace.declaration": "#66D9E8",
    "namespace.static": "#66D9E8",
    "parameter.declaration": "#F4D35E",
    "parameter.static": "#F4D35E",
    "property.declaration": "#9CDCFE",
    "property.static": "#9CDCFE",
    "type.static": "#66D9E8",
    "variable.declaration": "#D7E0EA",
    "variable.local": "#D7E0EA",
    "variable.static": "#D7E0EA",
    "variable.readonly": "#D7E0EA",
    "property.readonly": "#9CDCFE",
    "parameter.readonly": "#F4D35E",
    "function.defaultLibrary": "#9CDCFE",
    "variable.defaultLibrary": "#9CDCFE",
    "namespace.defaultLibrary": "#66D9E8",
    "namespace.imported": "#66D9E8",
    "variable.deprecated": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" },
    "function.deprecated": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" },
    "property.deprecated": { "foreground": "#FF5C7A", "fontStyle": "strikethrough" },
    "type.unit": "#F4D35E",
    "property.unit": "#F4D35E",
    "type.quantity": "#66D9E8",
    "variable.quantity": "#66D9E8",
    "property.quantity": "#66D9E8",
    "parameter.quantity": "#66D9E8",
    "variable.axis": "#56C2C1",
    "property.axis": "#56C2C1",
    "type.axis": "#56C2C1",
    "variable.timeseries": "#8DD694",
    "property.timeseries": "#8DD694",
    "function.timeseries": "#8DD694",
    "keyword.timeseries": "#8DD694",
    "variable.uncertain": "#D6A3FF",
    "function.uncertain": "#D6A3FF",
    "keyword.uncertain": "#D6A3FF",
    "property.uncertain": "#D6A3FF",
    "keyword.workflowStep": "#82AAFF",
    "function.workflowStep": "#82AAFF",
    "variable.workflowStep": "#82AAFF",
    "property.workflowStep": "#82AAFF",
    "keyword.validation": "#F7C56B",
    "function.validation": "#F7C56B",
    "variable.validation": "#F7C56B",
    "property.validation": "#F7C56B",
    "keyword.report": "#C792EA",
    "function.report": "#C792EA",
    "variable.report": "#C792EA",
    "property.report": "#C792EA",
    "keyword.sideEffect": "#FF8A8A",
    "function.sideEffect": "#FF8A8A",
    "method.sideEffect": "#FF8A8A",
    "variable.sideEffect": "#FF8A8A",
    "property.sideEffect": "#FF8A8A",
    "keyword.external": "#FFB86B",
    "function.external": "#FFB86B",
    "method.external": "#FFB86B",
    "variable.external": "#FFB86B",
    "property.external": "#FFB86B",
    "keyword.solver": "#80CBC4",
    "function.solver": "#80CBC4",
    "variable.solver": "#80CBC4",
    "property.solver": "#80CBC4",
    "keyword.model": "#C792EA",
    "function.model": "#C792EA",
    "variable.model": "#C792EA",
    "property.model": "#C792EA",
    "keyword.db": "#4DD0E1",
    "function.db": "#4DD0E1",
    "method.db": "#4DD0E1",
    "variable.db": "#4DD0E1",
    "property.db": "#4DD0E1",
    "keyword.cache": "#A3E635",
    "function.cache": "#A3E635",
    "variable.cache": "#A3E635",
    "property.cache": "#A3E635",
    "keyword.state": "#B9F27C",
    "variable.state": "#B9F27C",
    "property.state": "#B9F27C",
    "keyword.input": "#9CDCFE",
    "variable.input": "#9CDCFE",
    "parameter.input": "#9CDCFE",
    "keyword.output": "#F4D35E",
    "variable.output": "#F4D35E",
    "variable.riskHigh": { "foreground": "#FF5C7A", "fontStyle": "bold underline" },
    "keyword.riskHigh": { "foreground": "#FF5C7A", "fontStyle": "bold underline" },
    "class.riskHigh": { "foreground": "#FF5C7A", "fontStyle": "bold underline" },
    "property.riskHigh": { "foreground": "#FF5C7A", "fontStyle": "bold underline" },
    "variable.riskMedium": { "foreground": "#FFB454", "fontStyle": "underline" },
    "keyword.riskMedium": { "foreground": "#FFB454", "fontStyle": "underline" },
    "class.riskMedium": { "foreground": "#FFB454", "fontStyle": "underline" },
    "property.riskMedium": { "foreground": "#FFB454", "fontStyle": "underline" },
    "namespace.planned": { "foreground": "#7B8491", "fontStyle": "italic" },
    "namespace.internal": { "foreground": "#7B8491", "fontStyle": "italic" },
    "variable.planned": { "foreground": "#7B8491", "fontStyle": "italic" },
    "variable.internal": { "foreground": "#7B8491", "fontStyle": "italic" }
  }
}
