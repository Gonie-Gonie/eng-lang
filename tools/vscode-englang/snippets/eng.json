{
  "Regression prediction table": {
    "prefix": "predict table",
    "body": [
      "${1:model} = train regression ${2:training_results}",
      "with {",
      "    target = ${3:annual_electricity}",
      "    features = [${4:cooling_cop}]",
      "    test = ${5:0.25}",
      "    seed = ${6:7}",
      "}",
      "${7:model_card_summary} = model_card(${1:model})",
      "${8:model_metrics} = evaluate(${1:model})",
      "${9:predictions} = predict ${1:model} using ${10:designs}"
    ],
    "description": "Create a native regression model and prediction table."
  },
  "System model": {
    "prefix": "system thermal",
    "body": [
      "system ${1:Room} {",
      "    state ${2:T}: AbsoluteTemperature = ${3:20 degC}",
      "    parameter ${4:C}: HeatCapacity = ${5:1200 kJ/K}",
      "    parameter ${6:UA}: Conductance = ${7:250 W/K}",
      "    input ${8:T_out}: AbsoluteTemperature = ${9:10 degC}",
      "    input ${10:Q_internal}: HeatRate = ${11:500 W}",
      "    equation energy_balance:",
      "        ${4:C} * der(${2:T}) eq ${6:UA} * (${8:T_out} - ${2:T}) + ${10:Q_internal}",
      "}"
    ],
    "description": "Create a first-order thermal system model."
  },
  "Domain ports": {
    "prefix": "domain ports",
    "body": [
      "domain ${1:Thermal} package \"${2:eng.std.domains.thermal}\" version \"${3:0.1.0}\" {",
      "    across ${4:T}: AbsoluteTemperature [degC]",
      "    through ${5:Q}: HeatRate [kW]",
      "    conservation sum(${5:Q}) = 0",
      "}",
      "",
      "domain ${6:Fluid}[${7:Medium M}] package \"${8:eng.std.domains.fluid}\" version \"${9:0.1.0}\" {",
      "    across ${10:height}: Length [m]",
      "    through ${11:m_dot}: MassFlowRate [kg/s]",
      "    conservation sum(${11:m_dot}) = 0",
      "}",
      "",
      "domain ${12:MechanicalNode}[${13:Frame F}, ${14:Axis DOF}] package \"${15:eng.std.domains.mechanical}\" version \"${16:0.1.0}\" {",
      "    across ${17:x}: Length [m]",
      "    through ${18:P}: MechanicalPower [W]",
      "    conservation sum(${18:P}) = 0",
      "}",
      "",
      "component ${19:RoomBoundary} {",
      "    port ${20:heat}: ${1:Thermal}",
      "}",
      "",
      "component ${21:SupplyPipe} {",
      "    port ${22:inlet}: ${6:Fluid}[${23:Water}]",
      "    port ${24:outlet}: ${6:Fluid}[${23:Water}]",
      "}",
      "",
      "component ${25:ShaftA} {",
      "    port ${26:shaft}: ${12:MechanicalNode}[${27:World}, ${28:X}]",
      "}",
      "",
      "component ${29:ShaftB} {",
      "    port ${30:shaft}: ${12:MechanicalNode}[${27:World}, ${28:X}]",
      "}",
      "",
      "connect ${21:SupplyPipe}.${22:inlet} -> ${21:SupplyPipe}.${24:outlet}",
      "connect ${25:ShaftA}.${26:shaft} -> ${29:ShaftB}.${30:shaft}"
    ],
    "description": "Create package/version domains, generic ports, and a compatible connection."
  }
}