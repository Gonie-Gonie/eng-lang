{
  "Top-level workflow": {
    "prefix": "top workflow",
    "body": [
      "args {",
      "    ${1:input}: CsvFile = file(\"${2:data/sensor.csv}\")",
      "}",
      "",
      "${3:Q}: HeatRate [kW] = ${4:1 kW}",
      "print \"${5:case ready}\"",
      "log info \"${6:Q = {Q: .2 kW}}\"",
      "",
      "report {",
      "    show ${3:Q}",
      "}"
    ],
    "description": "Create a top-level EngLang workflow."
  },
  "Args block": {
    "prefix": "args block",
    "body": [
      "args {",
      "    ${1:input}: CsvFile = file(\"${2:data/sensor.csv}\")",
      "}"
    ],
    "description": "Create the root CLI argument block."
  },
  "Log message": {
    "prefix": "log info",
    "body": [
      "log ${1|info,warn,debug,error|} \"${2:message}\""
    ],
    "description": "Create a structured runtime log message."
  },
  "Native HTTP GET": {
    "prefix": "http get",
    "body": [
      "${1:response} = http get ${2:args.api_url}",
      "with {",
      "    query = {",
      "        ${3:station} = ${4:args.station_id}",
      "    }",
      "    offline_response = file(\"${5:data/response.json}\")",
      "    expected_sha256 = \"${6:sha256}\"",
      "    retry = ${7:2}",
      "    timeout = ${8:30 s}",
      "    body_size_limit = ${9:2 MB}",
      "    cache = true",
      "    cache_key = [\"${10:http}\", ${11:args.year}]",
      "}"
    ],
    "description": "Create a native pinned HTTP GET boundary."
  },
  "Native HTTP POST body": {
    "prefix": "http post",
    "body": [
      "${1:response} = http post ${2:args.api_url}",
      "with {",
      "    headers = {",
      "        content_type = \"application/json\"",
      "    }",
      "    body = ${3:request_body}",
      "    offline_response = file(\"${4:data/response.json}\")",
      "    expected_sha256 = \"${5:sha256}\"",
      "    timeout = ${6:30 s}",
      "    body_size_limit = ${7:2 MB}",
      "    cache = true",
      "    cache_key = [\"${8:post}\", ${9:args.case_id}]",
      "}"
    ],
    "description": "Create a native HTTP POST boundary with a request body."
  },
  "Sample LHS table": {
    "prefix": "sample lhs",
    "body": [
      "${1:designs} = sample lhs",
      "with {",
      "    count = ${2:8}",
      "    seed = ${3:42}",
      "    ${4:cooling_cop} = uniform(${5:2.5}, ${6:5.0})",
      "    ${7:load_index} = uniform(${8:0.85}, ${9:1.20})",
      "}"
    ],
    "description": "Create a deterministic native LHS sample table."
  },
  "Sample grid table": {
    "prefix": "sample grid",
    "body": [
      "${1:grid_samples} = sample grid",
      "with {",
      "    count = ${2:9}",
      "    ${3:cooling_cop} = uniform(${4:2.5}, ${5:5.0})",
      "    ${6:load_index} = uniform(${7:0.85}, ${8:1.20})",
      "}"
    ],
    "description": "Create a deterministic native grid sample table."
  },
  "Sample random table": {
    "prefix": "sample random",
    "body": [
      "${1:random_samples} = sample random",
      "with {",
      "    count = ${2:8}",
      "    seed = ${3:42}",
      "    ${4:cooling_cop} = uniform(${5:2.5}, ${6:5.0})",
      "    ${7:load_index} = uniform(${8:0.85}, ${9:1.20})",
      "}"
    ],
    "description": "Create a seeded native random sample table."
  },
  "Sample uniform table": {
    "prefix": "sample uniform",
    "body": [
      "${1:uniform_samples} = sample uniform",
      "with {",
      "    count = ${2:8}",
      "    seed = ${3:42}",
      "    ${4:cooling_cop} = uniform(${5:2.5}, ${6:5.0})",
      "    ${7:load_index} = uniform(${8:0.85}, ${9:1.20})",
      "}"
    ],
    "description": "Create a seeded native uniform/random sample table."
  },
  "Materialize cases": {
    "prefix": "materialize cases",
    "body": [
      "${1:cases} = materialize cases ${2:training_results}"
    ],
    "description": "Materialize native case rows from a table."
  },
  "Apply case template": {
    "prefix": "apply cases",
    "body": [
      "${1:case_inputs} = apply ${2:case_input_template} over ${3:cases}",
      "with {",
      "    template = file(\"${4:model/native_case_template.txt}\")",
      "    output = \"{case_dir}/${5:input.txt}\"",
      "    missing = error",
      "    overwrite = true",
      "}"
    ],
    "description": "Render per-case input files with the native template workflow."
  },
  "Regression prediction table": {
    "prefix": "predict table",
    "body": [
      "${1:model} = train regression ${2:training_results}",
      "with {",
      "    target = ${3:annual_electricity}",
      "    features = [${4:cooling_cop}]",
      "    test = ${5:0.25}",
      "    seed = ${6:7}",
      "}",
      "${7:model_card_summary} = model_card(${1:model})",
      "${8:model_metrics} = evaluate(${1:model})",
      "${9:predictions} = predict ${1:model} using ${10:designs}"
    ],
    "description": "Create a native regression model and prediction table."
  },
  "SQLite table write": {
    "prefix": "write sqlite",
    "body": [
      "${1:db} = open sqlite ${2:args.database_target}",
      "write ${3:predictions} to ${1:db}.table(\"${4:predictions}\")",
      "with {",
      "    mode = ${5|replace,append,upsert|}",
      "    transaction = commit",
      "}"
    ],
    "description": "Write a native table to SQLite with reviewable DB metadata."
  },
  "Standard text artifact": {
    "prefix": "write standard_text",
    "body": [
      "write standard_text ${1:weather}",
      "with {",
      "    output = join(${2:args.output}, \"${3:standard_weather_file.txt}\")",
      "    overwrite = true",
      "}"
    ],
    "description": "Write a deterministic standard_text artifact from a table."
  },
  "Run command": {
    "prefix": "run command",
    "body": [
      "${1:process_result} = run command \"${2:cmd}\"",
      "with {",
      "    args = [\"${3:/C}\", \"${4:echo}\", \"${5:ok}\"]",
      "}"
    ],
    "description": "Run an external command and capture a ProcessResult."
  },
  "Test block": {
    "prefix": "test block",
    "body": [
      "test \"${1:summary values}\" {",
      "    assert ${2:mean_Q} > ${3:0 kW}",
      "    assert ${4:E_coil} == ${5:1.26 kWh} within ${6:0.02 kWh}",
      "    golden \"${7:summary.csv}\" matches file(\"${8:golden/summary.csv}\")",
      "}"
    ],
    "description": "Create unit-aware assertions and a golden artifact comparison."
  },
  "CSV schema": {
    "prefix": "schema csv",
    "body": [
      "schema ${1:Sensor} {",
      "    ${2:time}: DateTime [iso8601]",
      "    ${3:T_supply}: AbsoluteTemperature [degC]",
      "    ${4:heat}: HeatRate [kW]",
      "}"
    ],
    "description": "Create a typed CSV schema."
  },
  "System model": {
    "prefix": "system thermal",
    "body": [
      "system ${1:Room} {",
      "    state ${2:T}: AbsoluteTemperature = ${3:20 degC}",
      "    parameter ${4:C}: HeatCapacity = ${5:1200 kJ/K}",
      "    parameter ${6:UA}: Conductance = ${7:250 W/K}",
      "    input ${8:T_out}: AbsoluteTemperature = ${9:10 degC}",
      "    input ${10:Q_internal}: HeatRate = ${11:500 W}",
      "    equation energy_balance:",
      "        ${4:C} * der(${2:T}) eq ${6:UA} * (${8:T_out} - ${2:T}) + ${10:Q_internal}",
      "}"
    ],
    "description": "Create a first-order thermal system model."
  },
  "Domain ports": {
    "prefix": "domain ports",
    "body": [
      "domain ${1:Thermal} package \"${2:eng.std.domains.thermal}\" version \"${3:0.1.0}\" {",
      "    across ${4:T}: AbsoluteTemperature [degC]",
      "    through ${5:Q}: HeatRate [kW]",
      "    conservation sum(${5:Q}) = 0",
      "}",
      "",
      "domain ${6:Fluid}[${7:Medium M}] package \"${8:eng.std.domains.fluid}\" version \"${9:0.1.0}\" {",
      "    across ${10:height}: Length [m]",
      "    through ${11:m_dot}: MassFlowRate [kg/s]",
      "    conservation sum(${11:m_dot}) = 0",
      "}",
      "",
      "domain ${12:MechanicalNode}[${13:Frame F}, ${14:Axis DOF}] package \"${15:eng.std.domains.mechanical}\" version \"${16:0.1.0}\" {",
      "    across ${17:x}: Length [m]",
      "    through ${18:P}: MechanicalPower [W]",
      "    conservation sum(${18:P}) = 0",
      "}",
      "",
      "component ${19:RoomBoundary} {",
      "    port ${20:heat}: ${1:Thermal}",
      "}",
      "",
      "component ${21:SupplyPipe} {",
      "    port ${22:inlet}: ${6:Fluid}[${23:Water}]",
      "    port ${24:outlet}: ${6:Fluid}[${23:Water}]",
      "}",
      "",
      "component ${25:ShaftA} {",
      "    port ${26:shaft}: ${12:MechanicalNode}[${27:World}, ${28:X}]",
      "}",
      "",
      "component ${29:ShaftB} {",
      "    port ${30:shaft}: ${12:MechanicalNode}[${27:World}, ${28:X}]",
      "}",
      "",
      "connect ${21:SupplyPipe}.${22:inlet} -> ${21:SupplyPipe}.${24:outlet}",
      "connect ${25:ShaftA}.${26:shaft} -> ${29:ShaftB}.${30:shaft}"
    ],
    "description": "Create package/version domains, generic ports, and a compatible connection."
  },
  "Plot line": {
    "prefix": "plot line",
    "body": [
      "report {",
      "    plot ${1:series} over Time",
      "    with {",
      "        unit y = ${2:kW}",
      "        title = \"${3:Series over time}\"",
      "    }",
      "}"
    ],
    "description": "Create a report line plot request with axis options."
  }
}
